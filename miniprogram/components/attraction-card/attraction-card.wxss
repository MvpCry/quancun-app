/* components/attraction-card/attraction-card.wxss */
.attraction-card {
  background: #FFFFFF;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 220rpx;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.card-favorite {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 32rpx;
}

.card-info {
  padding: 20rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-review-count {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: 12rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-address {
  flex: 1;
  font-size: 22rpx;
  color: var(--text-hint);
}

.card-price {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 600;
}

.card-price.free {
  color: var(--primary);
  font-size: 22rpx;
}
