/* components/map-route/map-route.wxss */
.map-route-container {
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
}

.route-map {
  width: 100%;
  border-radius: var(--radius);
}

/* 地图控制按钮 */
.map-controls {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-control-item {
  width: 64rpx;
  height: 64rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}

.control-icon {
  font-size: 32rpx;
  color: #333333;
}

/* 底部景点选择器 */
.stop-selector {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  white-space: nowrap;
  padding: 12rpx 0;
}

.stop-chip {
  display: inline-flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 10rpx 24rpx 10rpx 14rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  max-width: 240rpx;
}

.stop-chip.selected {
  background: var(--primary);
}

.stop-chip.selected .stop-chip-name {
  color: #FFFFFF;
}

.stop-chip.current {
  border: 2rpx solid var(--accent);
}

.stop-chip-order {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--primary-light);
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.stop-chip:first-child .stop-chip-order {
  background: var(--accent);
}

.stop-chip:last-child .stop-chip-order {
  background: var(--primary);
}

.stop-chip-name {
  font-size: 24rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
