/* components/route-card/route-card.wxss */
.route-card {
  background: #FFFFFF;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
}

.route-cover-wrap {
  position: relative;
  width: 100%;
  height: 240rpx;
}

.route-cover {
  width: 100%;
  height: 100%;
}

.route-cover-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.route-cover-info {
  position: absolute;
  bottom: 20rpx;
  left: 24rpx;
  right: 24rpx;
}

.route-name-on-cover {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 10rpx;
}

.route-tags {
  display: flex;
  flex-wrap: wrap;
}

.route-tag {
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.route-body {
  padding: 24rpx;
}

.route-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.route-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.route-meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-right: 28rpx;
}

.route-meta-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
}

/* 路线景点预览 */
.route-attractions-preview {
  padding: 8rpx 0;
}

.route-stop {
  display: flex;
  align-items: center;
  position: relative;
  padding: 10rpx 0;
}

.stop-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--primary-light);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.stop-dot:first-child {
  background: var(--accent);
  width: 18rpx;
  height: 18rpx;
}

.stop-dot:last-child {
  background: var(--primary);
  width: 18rpx;
  height: 18rpx;
}

.stop-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
}

.stop-location {
  font-size: 20rpx;
  color: var(--text-hint);
}

.stop-line {
  position: absolute;
  left: 6rpx;
  top: 32rpx;
  width: 2rpx;
  height: 28rpx;
  background: #DDDDDD;
}

/* 底部操作栏 */
.route-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
  margin-top: 8rpx;
}

.route-nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #2E8B57, #3CB371);
  border-radius: 36rpx;
  line-height: 1.4;
}

.route-nav-icon {
  font-size: 28rpx;
}
