<!-- custom-tab-bar/index.wxml - 底部导航栏 -->
<view class="tab-bar">
  <view
    class="tab-bar-item"
    wx:for="{{list}}"
    wx:key="pagePath"
    bindtap="onTabTap"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
  >
    <!-- 图标区：选中时填充绿色圆角背景 -->
    <view class="tab-icon-box {{selected === index ? 'tab-icon-box-active' : ''}}">
      <image
        class="tab-icon {{selected === index ? 'tab-icon-active' : ''}}"
        src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
        mode="aspectFit"
      />
    </view>

    <!-- 文字 -->
    <text class="tab-text {{selected === index ? 'tab-text-active' : ''}}">
      {{item.text}}
    </text>
  </view>
</view>
