/* custom-tab-bar/index.wxss - 底部导航栏（森林绿主题） */

/* ==================== 容器 ==================== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 100rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 999;
}

/* ==================== 每个 Tab 项 ==================== */
.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
  padding-top: 6rpx;
}

/* ==================== 图标外框 ==================== */
.tab-icon-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: transparent;
  transition: background 0.2s, transform 0.2s;
  margin-bottom: 4rpx;
}

/* 选中态 — 浅绿填充圆角背景 */
.tab-icon-box-active {
  background: #e8f5e9;
}

/* ==================== 图标 ==================== */
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  pointer-events: none;
  opacity: 0.45;
  transition: opacity 0.2s, transform 0.2s;
}

/* 选中态 — 图标变为实色 + 轻微放大 */
.tab-icon-active {
  opacity: 1;
  transform: scale(1.1);
}

/* ==================== 文字 ==================== */
.tab-text {
  font-size: 20rpx;
  color: #999;
  line-height: 1.3;
  pointer-events: none;
  transition: color 0.2s, font-weight 0.2s;
}

.tab-text-active {
  color: #2E8B57;
  font-weight: 600;
}
