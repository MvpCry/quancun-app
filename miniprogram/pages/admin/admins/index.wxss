/* pages/admin/admins/index.wxss */

/* 自定义导航栏（左箭头+居中标题+右胶囊）*/
.nav-container{width:100%;background:#2E8B57;box-sizing:border-box;padding-top:calc(env(safe-area-inset-top) + 36rpx);padding-bottom:16rpx;min-height:140rpx;display:flex;flex-direction:row;align-items:flex-end;justify-content:space-between;}
.nav-container.android{padding-top:calc(env(safe-area-inset-top) + 40rpx)!important;align-items:center}
.nav-left{width:100rpx;flex-shrink:0;display:flex;align-items:center;padding-left:30rpx}.nav-center{flex:1;display:flex;justify-content:center;align-items:center}.nav-right{width:180rpx;flex-shrink:0}.nav-title{font-size:36rpx;color:#fff;font-weight:600;padding:12rpx 0;white-space:nowrap}


/* pages/admin/admins/index.wxss */

/* 顶部卡片 */
.top-bar{background:linear-gradient(135deg,#E8F5E9 0%,#FFF 40%);border-radius:16rpx;padding:28rpx 28rpx 18rpx;margin-bottom:20rpx;box-shadow:0 2px 12px rgba(0,0,0,.05)}
.top-title-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:22rpx}
.top-title-left{display:flex;align-items:center;gap:10rpx}
.top-icon{font-size:36rpx}
.top-title{font-size:38rpx;font-weight:700;color:#228B22;white-space:nowrap}
.top-count{font-size:24rpx;color:#999;white-space:nowrap}

/* 搜索栏 */
.search-bar{display:flex;gap:12rpx;align-items:center}
.search-input-wrap{display:flex;align-items:center;flex:1;background:#FFF;border-radius:40rpx;padding:4rpx 24rpx;box-shadow:0 1px 6px rgba(0,0,0,.06);border:1rpx solid #E8E8E8}
.search-icon{font-size:28rpx;margin-right:10rpx;flex-shrink:0}
.search-input{flex:1;height:68rpx;font-size:26rpx;border:none;background:transparent}

/* 区块标题 */
.section-title{font-size:28rpx;font-weight:600;color:#666;margin:24rpx 0 16rpx;padding-left:4rpx}

/* 按钮 */
.btn-sm{padding:14rpx 24rpx;border-radius:40rpx;font-size:26rpx;border:none;flex-shrink:0}
.btn-sm::after{border:none}
.green{background:#2E8B57;color:#FFF}
.gray{background:#666;color:#FFF}

/* 搜索结果 */
.result-hint{font-size:24rpx;color:#999;margin-bottom:12rpx;display:block}
.search-results{background:#FFF;border-radius:12rpx;padding:16rpx 24rpx;margin-bottom:20rpx;box-shadow:0 2px 8px rgba(0,0,0,.06)}

.user-item{display:flex;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #F5F5F5}
.user-item:last-child{border-bottom:none}
.user-avatar{width:72rpx;height:72rpx;border-radius:50%;margin-right:16rpx;background:#F0F0F0;flex-shrink:0}
.user-info{flex:1;overflow:hidden}
.user-name{font-size:28rpx;font-weight:500;display:block}
.user-openid{font-size:22rpx;color:#BBB;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.already-admin{font-size:24rpx;color:#2E8B57;flex-shrink:0;padding:8rpx 16rpx;background:#E8F5E9;border-radius:20rpx}

/* 管理员列表 */
.admin-list{background:#FFF;border-radius:12rpx;box-shadow:0 2px 8px rgba(0,0,0,.06);overflow:hidden}
.admin-item{display:flex;align-items:center;padding:22rpx 24rpx;border-bottom:1rpx solid #F5F5F5}
.admin-item:last-child{border-bottom:none}
.admin-avatar{width:72rpx;height:72rpx;border-radius:50%;margin-right:16rpx;background:#F0F0F0;flex-shrink:0}
.admin-info{flex:1;overflow:hidden}
.admin-name{font-size:28rpx;font-weight:500;display:block}
.admin-time{font-size:22rpx;color:#BBB;display:block}
.admin-tag{font-size:22rpx;color:#2E8B57;background:#E8F5E9;padding:6rpx 16rpx;border-radius:20rpx;margin-right:12rpx;flex-shrink:0}
.remove-btn{font-size:26rpx;color:#E53935;padding:8rpx 16rpx;flex-shrink:0}

/* 空状态 */
.empty-state{padding:80rpx 0;text-align:center}
.empty-text{font-size:28rpx;color:#BBB}

.loading-state{padding:80rpx 0;text-align:center;font-size:28rpx;color:#999}
