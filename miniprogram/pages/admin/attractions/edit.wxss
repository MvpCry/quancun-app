/* 自定义导航栏（左箭头+居中标题+右胶囊）*/
.nav-container{width:100%;background:#2E8B57;box-sizing:border-box;padding-top:calc(env(safe-area-inset-top) + 36rpx);padding-bottom:16rpx;min-height:140rpx;display:flex;flex-direction:row;align-items:flex-end;justify-content:space-between;}
.nav-container.android{padding-top:calc(env(safe-area-inset-top) + 40rpx)!important;align-items:center}
.nav-left{width:100rpx;flex-shrink:0;display:flex;align-items:center;padding-left:30rpx}.nav-center{flex:1;display:flex;justify-content:center;align-items:center}.nav-right{width:180rpx;flex-shrink:0}.nav-title{font-size:36rpx;color:#fff;font-weight:600;padding:12rpx 0;white-space:nowrap}


.container{padding:24rpx;padding-bottom:140rpx}

/* 表单分区 */
.form-section{margin-bottom:40rpx}
.section-label{font-size:30rpx;font-weight:700;color:#228B22;display:block;margin-bottom:20rpx;padding-left:16rpx;border-left:6rpx solid #3CB371}

.form-grp{margin-bottom:24rpx}.label{font-size:28rpx;font-weight:600;display:block;margin-bottom:10rpx;color:#333}
.inp{width:100%;padding:18rpx 24rpx;background:#FFF;border-radius:12rpx;font-size:28rpx;box-shadow:0 2px 8px rgba(0,0,0,.04)}
.txa{width:100%;min-height:200rpx;padding:18rpx 24rpx;background:#FFF;border-radius:12rpx;font-size:28rpx;box-shadow:0 2px 8px rgba(0,0,0,.04)}
.hint{font-size:22rpx;color:#999;margin-bottom:10rpx;display:block}
.cat-row{display:flex;gap:16rpx}.cat-chip{padding:14rpx 32rpx;border-radius:40rpx;font-size:26rpx;background:#F5F5F5;color:#666}.cat-chip.active{background:#E8F5E9;color:#2E8B57;font-weight:600}

/* 行政区域字段 */
.locked-field{padding:18rpx 24rpx;background:#F5F5F5;border-radius:12rpx;font-size:28rpx;color:#666;border:1rpx solid #E8E8E8}
.picker-val{padding:18rpx 24rpx;background:#FFF;border-radius:12rpx;font-size:28rpx;box-shadow:0 2px 8px rgba(0,0,0,.04);min-height:68rpx}
.picker-placeholder{color:#BBB}
.flex-1{flex:1}

/* 地图搜索 */
.search-row{display:flex;gap:12rpx;margin-bottom:14rpx}
.search-btn{padding:18rpx 20rpx;background:#1976D2;color:#FFF;border-radius:12rpx;font-size:26rpx;border:none;flex-shrink:0;white-space:nowrap}.search-btn::after{border:none}.search-btn[disabled]{background:#BDBDBD}

.search-results{background:#FFF;border-radius:12rpx;box-shadow:0 2px 8px rgba(0,0,0,.06);overflow:hidden;margin-bottom:14rpx;max-height:500rpx;overflow-y:auto}
.result-item{display:flex;align-items:center;padding:20rpx;border-bottom:1rpx solid #F5F5F5}.result-item:last-child{border-bottom:none}.result-item.picked{background:#E8F5E9}
.result-left{flex:1;min-width:0}.result-title{font-size:28rpx;font-weight:500;display:block}.result-addr{font-size:22rpx;color:#999;display:block;margin-top:4rpx}
.result-pick{font-size:24rpx;color:#1976D2;flex-shrink:0;margin-left:12rpx}.result-check{font-size:24rpx;color:#2E8B57;font-weight:600;flex-shrink:0;margin-left:12rpx}
.search-empty{text-align:center;padding:40rpx 0;color:#999;font-size:26rpx}

/* 已选定位置 */
.location-picked-bar{display:flex;align-items:flex-start;gap:16rpx;padding:20rpx;background:#E8F5E9;border-radius:12rpx;border-left:6rpx solid #3CB371}
.lp-icon{font-size:36rpx}.lp-info{flex:1;min-width:0}.lp-title{font-size:28rpx;font-weight:600;display:block;color:#228B22}.lp-addr{font-size:24rpx;color:#666;display:block;margin-top:4rpx}.lp-coords{font-size:22rpx;color:#999;display:block;margin-top:4rpx}

/* 图片 */
.img-list{display:flex;flex-wrap:wrap;gap:16rpx}.img-item{position:relative;width:180rpx;height:180rpx;border-radius:12rpx;overflow:hidden}.img{width:100%;height:100%}.img-del{position:absolute;top:6rpx;right:6rpx;width:36rpx;height:36rpx;background:rgba(0,0,0,.6);color:#FFF;border-radius:50%;display:flex;align-items:flex-end;justify-content:space-between;font-size:22rpx}
.img-add{width:180rpx;height:180rpx;border:2rpx dashed #CCC;border-radius:12rpx;display:flex;flex-direction:column;align-items:flex-end;justify-content:space-between;gap:8rpx;background:#FAFAFA}.img-add-icon{font-size:48rpx;color:#999}.img-add-text{font-size:20rpx;color:#999}

.btn-bar{padding:24rpx 0}.btn-save{width:100%;padding:20rpx 0;font-size:30rpx;color:#FFF;background:#2E8B57;border-radius:44rpx;border:none;text-align:center}.btn-save::after{border:none}.btn-save[disabled]{background:#CCC}
