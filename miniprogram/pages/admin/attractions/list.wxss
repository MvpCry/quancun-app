/* ====== 自定义导航栏（左箭头+居中标题+右胶囊）====== */
.nav-container{width:100%;background:#2E8B57;box-sizing:border-box;padding-top:calc(env(safe-area-inset-top) + 36rpx);padding-bottom:16rpx;min-height:140rpx;display:flex;flex-direction:row;align-items:flex-end;justify-content:space-between;}
.nav-container.android{padding-top:calc(env(safe-area-inset-top) + 40rpx)!important;align-items:center}
.nav-left{width:100rpx;flex-shrink:0;display:flex;align-items:center;padding-left:30rpx}.nav-center{flex:1;display:flex;justify-content:center;align-items:center}.nav-right{width:180rpx;flex-shrink:0}.nav-title{font-size:36rpx;color:#fff;font-weight:600;padding:12rpx 0;white-space:nowrap}


/* ====== 顶部区域（卡片式） ====== */
.top-bar{
  background:linear-gradient(135deg, #E8F5E9 0%, #FFF 40%);
  border-radius:16rpx;
  padding:28rpx 28rpx 18rpx;
  margin-bottom:20rpx;
  box-shadow:0 2px 12px rgba(0,0,0,.05);
}

/* 标题行 */
.top-title-row{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:20rpx;
}
.top-title-left{display:flex;align-items:center;gap:10rpx}
.top-icon{font-size:36rpx}
.top-title{font-size:38rpx;font-weight:700;color:#228B22;white-space:nowrap}
.top-count{font-size:24rpx;color:#999;white-space:nowrap}

/* 操作按钮行 */
.top-actions{display:flex;align-items:center;gap:16rpx;margin-bottom:22rpx}
.btn-add{padding:16rpx 36rpx;background:#2E8B57;color:#FFF;border-radius:40rpx;font-size:28rpx;font-weight:600;border:none;box-shadow:0 2px 8px rgba(46,125,50,.25)}
.btn-add::after{border:none}

.btn-batch{padding:16rpx 28rpx;background:#FFF;color:#2E8B57;border:1.5rpx solid #2E8B57;border-radius:40rpx;font-size:26rpx}
.btn-batch::after{border:none}
.btn-batch.active{background:#FF9800;color:#FFF;border-color:#FF9800}

/* 搜索栏 */
.search-bar{margin:0}
.search-input-wrap{
  display:flex;align-items:center;
  background:#FFF;border-radius:40rpx;
  padding:4rpx 24rpx;
  box-shadow:0 1px 6px rgba(0,0,0,.06);
  border:1rpx solid #E8E8E8;
}
.search-icon{font-size:28rpx;margin-right:10rpx;flex-shrink:0}
.search-input{flex:1;height:68rpx;font-size:26rpx;border:none;background:transparent}
.search-btn{padding:14rpx 28rpx;background:#2E8B57;color:#FFF;border-radius:12rpx;font-size:26rpx;flex-shrink:0}

/* ====== Loading ====== */
.loading-state{text-align:center;padding:120rpx 0;color:#999;font-size:28rpx}

/* ====== 面包屑 ====== */
.breadcrumb{display:flex;align-items:center;padding:16rpx 0;margin-bottom:12rpx;flex-wrap:wrap}
.bc-item{font-size:26rpx;color:#2E8B57}
.bc-root{font-weight:600}
.bc-sep{color:#CCC;margin:0 6rpx;font-size:24rpx}
.bc-active{color:#333;font-weight:600}
.bc-total{font-size:24rpx;color:#999;margin-left:6rpx}

/* ====== 树形面板 ====== */
.tree-panel{background:#FFF;border-radius:12rpx;padding:12rpx 16rpx;margin-bottom:16rpx;box-shadow:0 2px 8px rgba(0,0,0,.04)}

.tree-branch{}

/* 缩进层级 */
.level-indent{padding-left:40rpx}

/* ====== 文件夹行 ====== */
.folder-row{display:flex;align-items:center;padding:16rpx 12rpx;border-radius:10rpx;margin:3rpx 0;transition:background .15s}
.folder-row:active{background:#F0F0F0}

/* Level 1: 省 */
.folder-l1{background:#F5F9F5}
.folder-l1.expanded{background:#E8F5E9}

/* Level 2: 地级市 */
.folder-l2{background:#FAFBFC}
.folder-l2.expanded{background:#EEF2F7}

/* Level 3: 区/县/县级市 */
.folder-l3{padding-left:20rpx}
.folder-l3.selected{background:#E3F2FD}
.folder-l3.selected .folder-name{color:#1565C0;font-weight:600}

.folder-arrow{width:32rpx;font-size:18rpx;color:#999;flex-shrink:0;text-align:center}
.folder-icon{font-size:28rpx;margin-right:8rpx;flex-shrink:0}
.folder-name{font-size:28rpx;font-weight:500}
.folder-count{font-size:24rpx;color:#999;margin-left:6rpx}

/* ====== 列表面板 ====== */
.list-panel{}
.list-header{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0 12rpx}
.list-title{font-size:28rpx;font-weight:600;color:#333}
.list-total{font-size:24rpx;color:#999}

/* ====== 景点卡片 ====== */
.list{display:flex;flex-direction:column;gap:16rpx}
.card{display:flex;background:#FFF;border-radius:12rpx;box-shadow:0 2px 8px rgba(0,0,0,.06);padding:20rpx;align-items:center;gap:16rpx}
.card-img{width:120rpx;height:120rpx;border-radius:12rpx;flex-shrink:0;background:#F0F0F0}
.card-body{flex:1;min-width:0}
.card-name{font-size:30rpx;font-weight:600;display:block;margin-bottom:4rpx}
.card-desc{font-size:24rpx;color:#999;display:block;margin-bottom:4rpx}
.card-addr-hint{font-size:22rpx;color:#BBB;display:block;margin-bottom:8rpx}
.card-tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:6rpx}
.tag{font-size:20rpx;padding:2rpx 12rpx;background:#F5F5F5;border-radius:8rpx;color:#666}
.card-meta{font-size:22rpx;color:#999;display:flex;gap:20rpx}
.card-actions{display:flex;flex-direction:column;gap:10rpx;flex-shrink:0}
.act{font-size:24rpx;padding:8rpx 16rpx;border-radius:8rpx;text-align:center}
.act.edit{color:#2E8B57;background:#E8F5E9}
.act.del{color:#E53935;background:#FFEBEE}
.act.featured-on{color:#FF9800;background:#FFF3E0}
.act.featured-off{color:#999;background:#F5F5F5}

/* ====== 空状态 ====== */
.empty-state{text-align:center;padding:80rpx 0;color:#999}
.empty-text{font-size:28rpx}
.tree-empty-hint{text-align:center;padding:100rpx 0}
.hint-icon{font-size:64rpx;display:block;margin-bottom:16rpx}
.hint-text{font-size:28rpx;color:#BBB}

/* ====== 未知空提示 ====== */
.unknown-empty{padding:12rpx 20rpx;text-align:center}
.empty-hint-text{font-size:22rpx;color:#3CB371}

/* ====== 树形空状态 ====== */
.tree-empty-state{text-align:center;padding:60rpx 0}
.empty-sub{font-size:24rpx;color:#BBB;display:block;margin-top:8rpx}

/* ====== 搜索结果区域路径标签 ====== */
.search-path-tags{display:flex;flex-wrap:wrap;align-items:center;gap:8rpx;margin-bottom:16rpx;padding:12rpx 0}
.path-tag-hint{font-size:22rpx;color:#999}
.path-tag{font-size:20rpx;color:#2E8B57;background:#E8F5E9;padding:4rpx 12rpx;border-radius:6rpx;max-width:60vw;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* ====== 批量选择复选框 ====== */
.card-check{padding:0 12rpx;flex-shrink:0}
.checkbox{width:40rpx;height:40rpx;border-radius:50%;border:2rpx solid #CCC;display:flex;align-items:flex-end;justify-content:space-between;font-size:24rpx;color:#FFF;transition:all .15s}
.checkbox.checked{background:#2E8B57;border-color:#2E8B57}

/* 选中卡片高亮 */
.card-selected{background:#F1F8E9;box-shadow:0 0 0 2rpx #3CB371 inset}

/* ====== 底部批量操作栏 ====== */
.batch-bar{position:fixed;bottom:0;left:0;right:0;background:#FFF;display:flex;align-items:center;padding:16rpx 24rpx;box-shadow:0 -2px 12px rgba(0,0,0,.08);gap:16rpx;z-index:100}
.batch-left{display:flex;align-items:center;gap:10rpx}
.batch-label{font-size:24rpx;color:#666}
.batch-count{font-size:26rpx;color:#333;font-weight:600;flex:1;text-align:center}
.batch-btn{padding:14rpx 28rpx;background:#2E8B57;color:#FFF;border-radius:40rpx;font-size:26rpx;border:none}
.batch-btn::after{border:none}

/* ====== 批量修正弹窗 ====== */
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:200;display:flex;align-items:flex-end;justify-content:space-between}
.modal-content{width:86vw;background:#FFF;border-radius:16rpx;padding:36rpx 32rpx}
.modal-title{font-size:30rpx;font-weight:700;color:#333;display:block;margin-bottom:28rpx;text-align:center}

/* 弹窗内表单 */
.modal-content .form-grp{margin-bottom:20rpx}
.modal-content .label{font-size:26rpx;font-weight:600;display:block;margin-bottom:8rpx;color:#333}
.modal-content .inp{width:100%;padding:16rpx 20rpx;background:#F9F9F9;border-radius:10rpx;font-size:26rpx;border:1rpx solid #E8E8E8}
.modal-content .picker-val{padding:16rpx 20rpx;background:#F9F9F9;border-radius:10rpx;font-size:26rpx;border:1rpx solid #E8E8E8;min-height:62rpx}
.modal-content .picker-placeholder{color:#BBB}

.modal-btns{display:flex;gap:20rpx;margin-top:24rpx}
.btn-cancel{flex:1;padding:18rpx 0;background:#F5F5F5;color:#666;border-radius:44rpx;font-size:28rpx;border:none;text-align:center}
.btn-cancel::after{border:none}
.btn-confirm{flex:1;padding:18rpx 0;background:#2E8B57;color:#FFF;border-radius:44rpx;font-size:28rpx;border:none;text-align:center}
.btn-confirm::after{border:none}
