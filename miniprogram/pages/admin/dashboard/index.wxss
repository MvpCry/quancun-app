/* 自定义导航栏（左箭头+居中标题+右胶囊）*/
.nav-container{width:100%;border-radius:0 0 48rpx 48rpx;background:linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);box-sizing:border-box;padding-top:calc(env(safe-area-inset-top) + 36rpx);padding-bottom:16rpx;min-height:140rpx;display:flex;flex-direction:row;align-items:flex-end;justify-content:space-between;}
.nav-container.android{padding-top:calc(env(safe-area-inset-top) + 40rpx)!important;align-items:center}
.nav-left{width:100rpx;flex-shrink:0;display:flex;align-items:center;padding-left:30rpx}.nav-center{flex:1;display:flex;justify-content:center;align-items:center}.nav-right{width:180rpx;flex-shrink:0}.nav-title{font-size:36rpx;color:#fff;font-weight:600;padding:12rpx 0;white-space:nowrap}


.admin-header{padding:32rpx 0 24rpx}.admin-title{font-size:40rpx;font-weight:700;display:block}.admin-sub{font-size:26rpx;color:#999;margin-top:8rpx;display:block}

.stat-grid{display:flex;flex-wrap:wrap;justify-content:space-between;margin-bottom:32rpx}
.stat-card{width:49%;padding:28rpx 20rpx;border-radius:12rpx;background:#FFF;box-shadow:0 2px 12px rgba(0,0,0,.08);margin-bottom:16rpx;box-sizing:border-box;position:relative}
.stat-card-hover{box-shadow:0 4px 16px rgba(0,0,0,.15);transform:translateY(-2rpx)}
.stat-arrow{position:absolute;right:14rpx;top:50%;transform:translateY(-50%);font-size:32rpx;color:#ccc;font-weight:300}
.stat-card.reviews{border-left:6rpx solid #2E8B57}.stat-card.violations{border-left:6rpx solid #FF9800}.stat-card.reports{border-left:6rpx solid #E53935}.stat-card.bans{border-left:6rpx solid #9C27B0}
.num{font-size:44rpx;font-weight:700;display:block}.label{font-size:24rpx;color:#666;margin-top:4rpx;display:block}.sub{font-size:20rpx;color:#999;margin-top:6rpx;display:block}

.menu-grid{display:flex;flex-wrap:wrap;justify-content:space-between;margin-bottom:32rpx}
.menu-card{width:49%;padding:28rpx 16rpx;background:#FFF;border-radius:12rpx;box-shadow:0 2px 12px rgba(0,0,0,.08);text-align:center;margin-bottom:16rpx;box-sizing:border-box}
.menu-icon{font-size:44rpx;display:block}.menu-name{font-size:26rpx;font-weight:600;margin-top:10rpx;display:block}.menu-desc{font-size:20rpx;color:#999;margin-top:6rpx;display:block}

.info-list{background:#FFF;border-radius:12rpx;box-shadow:0 2px 12px rgba(0,0,0,.08);overflow:hidden}
.info-row{display:flex;justify-content:space-between;align-items:center;padding:24rpx;border-bottom:1rpx solid #F5F5F5}.info-row:last-child{border-bottom:none}
.info-label{font-size:28rpx;color:#666}.info-value{font-size:28rpx;font-weight:600}
.section-title{font-size:30rpx;font-weight:700;padding:16rpx 0;margin-bottom:12rpx}
.loading-state{text-align:center;padding:100rpx 0;color:#999}

/* 无权限全屏页 */
.forbidden-page{min-height:100vh;background:linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 60%);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60rpx 40rpx;box-sizing:border-box}
.forbidden-card{background:#FFF;border-radius:24rpx;box-shadow:0 4px 24px rgba(0,0,0,.1);padding:60rpx 40rpx;text-align:center;width:100%;max-width:600rpx}
.forbidden-icon{font-size:80rpx;display:block;margin-bottom:24rpx}
.forbidden-title{font-size:36rpx;font-weight:700;color:#333;display:block;margin-bottom:16rpx}
.forbidden-desc{font-size:28rpx;color:#999;display:block;margin-bottom:32rpx}
.forbidden-openid{background:#FAFAFA;border-radius:12rpx;padding:20rpx;margin-bottom:16rpx}
.forbidden-label{font-size:24rpx;color:#999;display:block;margin-bottom:8rpx}
.forbidden-value{font-size:22rpx;color:#666;word-break:break-all;display:block}
.forbidden-hint{font-size:24rpx;color:#999;display:block;margin-bottom:40rpx}
.forbidden-btn{width:100%;background:linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);color:#FFF;font-size:30rpx;font-weight:600;border-radius:44rpx;padding:20rpx 0;border:none}.forbidden-btn::after{border:none}
