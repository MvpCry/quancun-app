<!-- pages/admin/featured/index.wxml - 精选景点管理 -->
<view class="container">
  <view class="page-header">
    <text class="page-title">⭐ 精选景点</text>
    <text class="page-count">{{total}} 个景点</text>
  </view>

  <view class="hint-text">上架的景点将展示在首页「精选景点」区块</view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索景点名称或地址..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>

  <view class="item-list" wx:if="{{!loading && attractions.length > 0}}">
    <view class="item-row" wx:for="{{attractions}}" wx:key="_id">
      <image class="item-thumb" src="{{item.coverImage || item.images[0]}}" mode="aspectFill"/>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-sub">{{item.address || ''}}</text>
      </view>
      <view class="item-toggle {{item.featured ? 'on' : 'off'}}" bindtap="onToggle" data-id="{{item._id}}" data-name="{{item.name}}" data-featured="{{item.featured}}">
        <text>{{item.featured ? '已上架' : '已下架'}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{!loading}}">
    <text class="empty-text">暂无景点数据</text>
  </view>

  <view class="safe-bottom" style="height:60rpx;"></view>
</view>
