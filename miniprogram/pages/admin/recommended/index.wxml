<!-- pages/admin/recommended/index.wxml - 推荐路线管理 -->
<view class="container">
  <view class="page-header">
    <text class="page-title">🗺️ 推荐路线</text>
    <text class="page-count">{{total}} 条路线</text>
  </view>

  <view class="hint-text">上架的路线将展示在首页「推荐路线」区块</view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索路线名称或描述..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch"/>
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>

  <view class="item-list" wx:if="{{!loading && routes.length > 0}}">
    <view class="item-row" wx:for="{{routes}}" wx:key="_id">
      <image class="item-thumb" src="{{item.coverImage || '/images/default-attraction.png'}}" mode="aspectFill"/>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-sub">{{item.description || ''}}</text>
      </view>
      <view class="item-toggle {{item.recommended ? 'on' : 'off'}}" bindtap="onToggle" data-id="{{item._id}}" data-name="{{item.name}}" data-recommended="{{item.recommended}}">
        <text>{{item.recommended ? '已上架' : '已下架'}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{!loading}}">
    <text class="empty-text">暂无路线数据</text>
  </view>

  <view class="safe-bottom" style="height:60rpx;"></view>
</view>
