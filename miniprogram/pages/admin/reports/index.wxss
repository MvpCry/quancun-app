.page-header{padding:24rpx 0 16rpx}.page-title{font-size:36rpx;font-weight:700}
.tab-bar{display:flex;background:#FFF;border-radius:12rpx;box-shadow:0 2px 8px rgba(0,0,0,.06);margin-bottom:16rpx;overflow:hidden}.tab-item{flex:1;text-align:center;padding:20rpx 0;font-size:26rpx;color:#666}.tab-item.active{color:#2E7D32;font-weight:600;border-bottom:4rpx solid #2E7D32}
.batch-bar{margin-bottom:16rpx}.batch-btn{width:100%;padding:16rpx;font-size:26rpx;color:#E53935;background:#FFF0F0;border:2rpx solid #FFCDD2;border-radius:12rpx}.batch-btn::after{border:none}
.report-list{display:flex;flex-direction:column;gap:16rpx}.report-card{background:#FFF;border-radius:12rpx;box-shadow:0 2px 8px rgba(0,0,0,.06);padding:24rpx}
.report-meta{display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx}.tag{font-size:22rpx;padding:4rpx 14rpx;border-radius:12rpx;background:#F5F5F5}.tag.red{background:#FFEBEE;color:#E53935}.status{font-size:22rpx;padding:4rpx 14rpx;border-radius:12rpx}.status.pending{background:#FFF3E0;color:#FF9800}.status.handled{background:#E8F5E9;color:#2E7D32}
.reported-content{background:#FAFAFA;border-radius:12rpx;padding:20rpx;margin-bottom:12rpx}.reported-content.deleted{background:#FFF0F0}.reported-header{display:flex;align-items:center;gap:16rpx;margin-bottom:10rpx}.reported-user{font-size:26rpx;font-weight:600}.reported-star{font-size:24rpx;color:#FF9800}.report-count{font-size:22rpx;color:#E53935}.reported-text{font-size:26rpx;color:#666;line-height:1.6}.deleted-text{color:#999;font-style:italic}
.report-time{font-size:22rpx;color:#999;display:block;margin-bottom:16rpx}
.report-actions{display:flex;gap:16rpx}.act-btn{flex:1;padding:14rpx 0;font-size:26rpx;border-radius:40rpx;text-align:center;border:none}.act-btn::after{border:none}.del{background:#FFEBEE;color:#E53935}.dismiss{background:#F5F5F5;color:#666}
/* 违规 */
.vl-list{display:flex;flex-direction:column;gap:12rpx}.vl-item{background:#FFF;border-radius:12rpx;padding:20rpx 24rpx;box-shadow:0 2px 8px rgba(0,0,0,.06)}.vl-header{display:flex;align-items:center;gap:12rpx;margin-bottom:10rpx}.vl-source{font-size:22rpx}.vl-source.keyword{color:#FF9800}.vl-source.msgSecCheck{color:#2196F3}.vl-word{font-size:22rpx;background:#FFEBEE;color:#E53935;padding:2rpx 12rpx;border-radius:8rpx}.vl-content{font-size:26rpx;color:#666;display:block;margin-bottom:8rpx;max-height:80rpx;overflow:hidden}.vl-time{font-size:22rpx;color:#999}
/* 禁言 */
.ban-list{display:flex;flex-direction:column;gap:12rpx}.ban-item{background:#FFF;border-radius:12rpx;padding:20rpx 24rpx;box-shadow:0 2px 8px rgba(0,0,0,.06)}.ban-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8rpx}.ban-user{font-size:26rpx;font-weight:500}.ban-tag{font-size:22rpx;padding:4rpx 14rpx;border-radius:12rpx;background:#FFF3E0;color:#FF9800}.ban-tag.week{background:#FFEBEE;color:#E53935}.ban-reason{font-size:24rpx;color:#666;display:block;margin-bottom:8rpx}.ban-footer{display:flex;justify-content:space-between;align-items:center}.ban-time{font-size:22rpx;color:#999}.lift-btn{padding:8rpx 20rpx;font-size:22rpx;background:#E8F5E9;color:#2E7D32;border-radius:20rpx;border:none}.lift-btn::after{border:none}
