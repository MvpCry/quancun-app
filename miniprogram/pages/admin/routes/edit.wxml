<view class="nav-container {{isAndroid ? 'android' : ''}}">
  <view class="nav-left">
    <view class="nav-back" bindtap="onNavBack"><text class="back-icon">{{backIcon}}</text></view>
  </view>
  <view class="nav-center">
    <text class="nav-title">{{isEdit ? '编辑路线' : '新增路线'}}</text>
  </view>
  <view class="nav-right"></view>
</view>
<scroll-view class="container" scroll-y>
  <!-- 路线名称 -->
  <view class="form-grp"><text class="label">路线名称 *</text><input class="inp" value="{{form.name}}" bindinput="onInput" data-field="name" placeholder="如：泰安乡村一日游"/></view>

  <!-- 封面图 -->
  <view class="form-grp"><text class="label">封面图</text>
    <view class="cover-area" bindtap="onChooseCover">
      <image class="cover-img" wx:if="{{form.coverImage}}" src="{{form.coverImage}}" mode="aspectFill"/>
      <view class="cover-placeholder" wx:else><text class="cover-icon">{{uploading ? '⏳' : '📷'}}</text><text>{{uploading ? '上传中...' : '点击上传封面图'}}</text></view>
    </view>
  </view>

  <!-- 简介 -->
  <view class="form-grp"><text class="label">路线简介</text><textarea class="txa" value="{{form.description}}" bindinput="onInput" data-field="description" placeholder="路线详细介绍..." maxlength="500"/></view>

  <!-- 分类标签（多选） -->
  <view class="form-grp"><text class="label">分类标签（多选）*</text>
    <view class="chip-grid">
      <view class="chip {{form.tags[item.key] ? 'active' : ''}}" wx:for="{{tagOptions}}" wx:key="key" bindtap="onTagToggle" data-key="{{item.key}}">{{item.label}}</view>
    </view>
    <text class="hint">勾选的标签决定路线在首页哪个分类入口展示</text>
  </view>

  <!-- 景点多选（核心） -->
  <view class="form-grp"><text class="label">包含景点（按游玩顺序勾选）*</text>
    <text class="hint" style="margin-bottom:12rpx">勾选顺序 = 游玩先后顺序，已选 {{form.selectedAttractions.length}} 个</text>

    <!-- 已选景点排序区 -->
    <view class="selected-bar" wx:if="{{form.selectedAttractions.length > 0}}">
      <text class="selected-title">游玩顺序：</text>
      <view class="selected-list">
        <view class="selected-item" wx:for="{{form.selectedAttractions}}" wx:key="*this">
          <view class="order-badge">{{index + 1}}</view>
          <text class="order-name text-ellipsis">{{selectedNames[index]}}</text>
          <text class="order-up" bindtap="onMoveUp" data-index="{{index}}" wx:if="{{index > 0}}">↑</text>
          <text class="order-del" bindtap="onAttractionToggle" data-id="{{item}}">✕</text>
        </view>
      </view>
    </view>

    <!-- 全部景点可选列表 -->
    <view class="attraction-pick-list">
      <view class="pick-item {{form.selectedAttractions.indexOf(item._id) >= 0 ? 'picked' : ''}}" wx:for="{{allAttractions}}" wx:key="_id" bindtap="onAttractionToggle" data-id="{{item._id}}">
        <view class="pick-check {{form.selectedAttractions.indexOf(item._id) >= 0 ? 'checked' : ''}}">
          <text wx:if="{{form.selectedAttractions.indexOf(item._id) >= 0}}">✓</text>
        </view>
        <view class="pick-info">
          <text class="pick-name">{{item.name}}</text>
          <text class="pick-addr text-ellipsis">{{item.address}}</text>
        </view>
        <text class="pick-cat">{{item.category === 'red' ? '红游' : item.category === 'rural' ? '乡村' : item.category === 'family' ? '亲子' : item.category === 'culture' ? '文化' : ''}}</text>
      </view>
    </view>
  </view>

  <!-- 提交 -->
  <view class="btn-bar safe-bottom">
    <button class="btn-save" bindtap="onSubmit" disabled="{{saving}}">
      {{saving ? '保存中...' : (isEdit ? '更新路线（自动计算里程）' : '创建路线（自动计算里程）')}}
    </button>
  </view>
</scroll-view>
