<view class="container">
  <view class="page-header">
    <text class="page-title">🗺️ 路线管理</text>
    <button class="btn-add" bindtap="onAdd">+ 新增路线</button>
  </view>
  <view class="list" wx:if="{{!loading && routes.length>0}}">
    <view class="card" wx:for="{{routes}}" wx:key="_id">
      <image class="card-img" src="{{item.coverImage}}" mode="aspectFill" wx:if="{{item.coverImage}}"/>
      <view class="card-body">
        <text class="card-name">{{item.name}}</text>
        <text class="card-desc text-ellipsis-2">{{item.description}}</text>
        <view class="card-tags"><text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text></view>
        <view class="card-meta"><text>📍 {{item.attractionCount || 0}}个景点</text><text>📏 {{item.totalDistance || '-'}}km</text><text>⏱ {{item.estimatedTime || '-'}}h</text></view>
      </view>
      <view class="card-actions">
        <text class="act edit" bindtap="onEdit" data-id="{{item._id}}">编辑</text>
        <text class="act del" bindtap="onDelete" data-id="{{item._id}}" data-name="{{item.name}}">删除</text>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:elif="{{!loading}}"><text class="empty-text">暂无路线，点击上方新增</text></view>
</view>
