<!-- pages/attractions/detail/detail.wxml - 景点详情页 -->
<!-- 布局顺序：名称 → 评分 → 开放时间 → 图片轮播 → 简介 → 地图 → 评论 -->
<view class="container">
  <!-- ========== 1. 名称 ========== -->
  <view class="name-section">
    <text class="detail-name">{{attraction.name}}</text>
  </view>

  <!-- ========== 2. 评分 ========== -->
  <view class="rating-section">
    <star-rating rating="{{attraction.rating}}" size="large" showText="{{true}}" readonly="{{true}}"/>
    <text class="rating-count">({{attraction.reviewCount || 0}}条评价)</text>
  </view>

  <!-- ========== 3. 开放时间 ========== -->
  <view class="time-section">
    <view class="time-row">
      <text class="time-icon">🕐</text>
      <text class="time-label">开放时间</text>
      <text class="time-value">{{attraction.openTime || '暂无'}}</text>
    </view>
    <view class="time-row">
      <text class="time-icon">🎫</text>
      <text class="time-label">门票</text>
      <text class="time-value price">{{attraction.ticketPrice > 0 ? '¥' + attraction.ticketPrice : '免费'}}</text>
    </view>
    <view class="time-row">
      <text class="time-icon">📍</text>
      <text class="time-label">地址</text>
      <text class="time-value address-text">{{attraction.address || '暂无'}}</text>
    </view>
  </view>

  <!-- ========== 4. 图片轮播 ========== -->
  <view class="swiper-section">
    <swiper class="detail-swiper" indicator-dots indicator-active-color="#FFFFFF" autoplay circular bindchange="onSwiperChange">
      <swiper-item wx:for="{{attraction.images}}" wx:key="*this">
        <image class="detail-image" src="{{item}}" mode="aspectFill" bindtap="onPreviewImage" data-url="{{item}}"/>
      </swiper-item>
    </swiper>
    <view class="image-count" wx:if="{{attraction.images && attraction.images.length > 1}}">
      {{currentImageIndex + 1}}/{{attraction.images.length}}
    </view>
  </view>

  <!-- ========== 5. 简介 ========== -->
  <view class="intro-section card">
    <view class="card-header">
      <text class="card-title">景点简介</text>
    </view>
    <view class="card-body">
      <text class="intro-text">{{attraction.introduction || '暂无简介'}}</text>
    </view>
  </view>

  <!-- ========== 6. 地图位置 ========== -->
  <view class="map-section card">
    <view class="card-header">
      <text class="card-title">景点位置</text>
      <text class="nav-btn" bindtap="onNavigate">🧭 导航前往</text>
    </view>
    <view class="map-wrap" bindtap="onOpenMap" wx:if="{{hasLocation}}">
      <map
        id="detailMap"
        class="detail-map"
        latitude="{{attraction.location.latitude}}"
        longitude="{{attraction.location.longitude}}"
        markers="{{markers}}"
        scale="15"
        show-location="{{true}}"
      />
    </view>
    <view class="map-wrap no-location" wx:else>
      <view class="no-location-hint">
        <text class="no-location-icon">📍</text>
        <text class="no-location-text">坐标待录入</text>
        <text class="no-location-desc">请通过后台管理页面设置此景点坐标</text>
      </view>
    </view>
  </view>

  <!-- ========== 7. 写评价 ========== -->
  <view class="write-review-section card">
    <view class="card-header">
      <text class="card-title">写评价</text>
    </view>

    <!-- 未登录提示 -->
    <view class="login-gate" wx:if="{{!isLogin}}">
      <view class="login-gate-content">
        <text class="login-gate-icon">🔒</text>
        <text class="login-gate-text">微信授权登录后才能发表评价</text>
        <button class="login-gate-btn" bindtap="onGoLogin">微信一键登录</button>
      </view>
    </view>

    <!-- 已登录 → 评价表单 -->
    <view class="write-review-form" wx:else>
      <!-- 用户身份 -->
      <view class="review-author">
        <image class="review-author-avatar" src="{{currentUser.avatarUrl}}" mode="aspectFill"/>
        <text class="review-author-name">{{currentUser.nickName}}</text>
      </view>

      <!-- 星级打分 -->
      <view class="write-review-stars">
        <text class="write-review-label">评分</text>
        <star-rating rating="{{myRating}}" size="large" readonly="{{false}}" bindchange="onReviewStarChange"/>
        <text class="write-review-rating-text">{{myRating}}分</text>
      </view>

      <!-- 评价输入 -->
      <view class="write-review-input-wrap {{reviewFocused || reviewContent ? 'focused' : ''}}">
        <textarea
          class="write-review-textarea"
          placeholder="分享你的真实体验（至少2个字）..."
          value="{{reviewContent}}"
          maxlength="500"
          auto-height
          bindinput="onReviewInput"
          bindfocus="onReviewFocus"
          bindblur="onReviewBlur"
        />
        <view class="write-review-footer">
          <text class="write-review-hint">客观真实的评价会自动展示</text>
          <text class="write-review-count {{reviewContent.length >= 500 ? 'full' : ''}}">{{reviewContent.length}}/500</text>
        </view>
      </view>

      <!-- 提交按钮 -->
      <button class="submit-review-btn {{submitting ? 'submitting' : ''}}" bindtap="onSubmitReview" disabled="{{submitting}}">
        {{submitting ? '发布中...' : '发布评价'}}
      </button>
    </view>
  </view>

  <!-- ========== 8. 评论列表 ========== -->
  <view class="review-section card">
    <view class="card-header">
      <text class="card-title">游客评价 ({{totalReviews}})</text>
    </view>
    <view class="review-list" wx:if="{{reviews.length > 0}}">
      <view class="review-item" wx:for="{{reviews}}" wx:key="_id">
        <view class="review-user">
          <image class="review-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
          <view class="review-user-info">
            <text class="review-name">{{item.userName}}</text>
            <text class="review-time">{{item.createTime}}</text>
          </view>
          <star-rating rating="{{item.rating}}" size="small" readonly="{{true}}"/>
        </view>
        <text class="review-content">{{item.content}}</text>
        <!-- 举报入口 -->
        <view class="review-report" bindtap="onReportReview" data-review-id="{{item._id}}" data-review-index="{{index}}">
          <text class="review-report-icon">⚑</text>
          <text class="review-report-text">举报</text>
        </view>
      </view>
    </view>
    <view class="no-reviews" wx:else>
      <text class="no-review-text">暂无评价，来说两句吧</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom">
    <view class="bottom-action" bindtap="onAddToRoute">
      <text class="bottom-icon">📍</text>
      <text class="bottom-label">加入路线</text>
    </view>
    <view class="bottom-action" bindtap="onNavigate">
      <text class="bottom-icon">🧭</text>
      <text class="bottom-label">导航</text>
    </view>
    <button class="bottom-btn btn-primary" bindtap="onAddToRoute">加入路线规划</button>
  </view>
</view>
