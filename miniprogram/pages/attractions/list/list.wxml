<!-- pages/attractions/list/list.wxml - 景点列表页 -->
<view class="container">
  <!-- 选择模式顶部栏 -->
  <view class="select-top-bar" wx:if="{{selectMode}}">
    <text class="select-cancel" bindtap="onCancelSelect">取消</text>
    <text class="select-title">选择景点 (已选{{selectedIds.length}}个)</text>
    <text class="select-confirm" bindtap="onConfirmSelect">完成</text>
  </view>

  <!-- 搜索栏（选择模式下隐藏） -->
  <view class="search-section" wx:if="{{!selectMode}}">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索景点名称..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" focus="{{focusSearch}}"/>
      <text class="search-clear" wx:if="{{keyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-filter" scroll-x enable-flex>
    <view class="filter-chip {{activeCategory === '' ? 'active' : ''}}" bindtap="onCategoryChange" data-category="">全部</view>
    <view class="filter-chip {{activeCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}" wx:key="id"
      bindtap="onCategoryChange"
      data-category="{{item.id}}">
      <image class="filter-chip-icon" src="{{item.icon}}" mode="aspectFit"/>
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 排序栏（选择模式下隐藏） -->
  <view class="sort-bar" wx:if="{{!selectMode}}">
    <view class="sort-item {{sortBy === 'rating' ? 'active' : ''}}" bindtap="onSortChange" data-sort="rating">
      评分最高
    </view>
    <view class="sort-item {{sortBy === 'reviewCount' ? 'active' : ''}}" bindtap="onSortChange" data-sort="reviewCount">
      最热门
    </view>
    <view class="sort-item {{sortBy === 'createTime' ? 'active' : ''}}" bindtap="onSortChange" data-sort="createTime">
      最新
    </view>
    <view class="sort-item {{sortBy === 'distance' ? 'active' : ''}}" bindtap="onSortChange" data-sort="distance">
      离我最近
    </view>
  </view>

  <!-- 搜索结果提示 -->
  <view class="search-result-header" wx:if="{{keyword && attractions.length > 0 && !selectMode}}">
    <text class="result-label">搜索"{{keyword}}"</text>
    <text class="result-count">找到 {{attractions.length}} 个结果</text>
  </view>

  <!-- 景点列表 -->
  <view class="attraction-list" wx:if="{{attractions.length > 0}}">
    <view class="attraction-row {{selectMode ? 'selectable' : ''}}" wx:for="{{attractions}}" wx:key="_id" bindtap="onAttractionTap" data-id="{{item._id}}">
      <!-- 选择模式：勾选框 -->
      <view class="select-check" wx:if="{{selectMode}}">
        <view class="checkbox {{item._selected ? 'checked' : ''}}">
          <text wx:if="{{item._selected}}">✓</text>
        </view>
      </view>

      <!-- 景点卡片 -->
      <attraction-card
        attraction="{{item}}"
        showFavorite="{{!selectMode}}"
        data-id="{{item._id}}"
        bindtap="onAttractionTap"
        bindfavorite="onFavoriteTap"
      />
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && attractions.length === 0}}">
    <text class="empty-icon">🏞️</text>
    <text class="empty-text">暂无景点信息</text>
    <text class="empty-hint">试试其他分类或搜索关键词</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && attractions.length > 0}}">
    <text wx:if="{{loadingMore}}">正在加载...</text>
    <text wx:else bindtap="loadMore">点击加载更多</text>
  </view>
  <view class="load-more" wx:if="{{!hasMore && attractions.length > 0}}">
    <text>— 已经到底了 —</text>
  </view>

  <!-- 选择模式底部栏 -->
  <view class="select-bottom-bar safe-bottom" wx:if="{{selectMode}}">
    <button class="btn btn-primary btn-block" bindtap="onConfirmSelect" disabled="{{selectedIds.length < 2}}">
      {{selectedIds.length < 2 ? '请至少选择2个景点 (已选' + selectedIds.length + '个)' : '完成选择，开始规划 (' + selectedIds.length + '个景点)'}}
    </button>
  </view>

  <view class="safe-bottom" style="height: 40rpx;" wx:if="{{!selectMode}}"></view>
</view>
