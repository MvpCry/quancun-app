/* pages/attractions/list/list.wxss - 景点列表样式（森林绿统一规范） */

/* ==================== 自定义导航栏 ==================== */
.nav-container {
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 0 0 48rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 16rpx;
  min-height: 140rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  overflow: hidden;
}

.nav-container.android {
  padding-top: calc(env(safe-area-inset-top) + 40rpx) !important;
  align-items: center;
}

.nav-left {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-left: 30rpx;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-right {
  width: 180rpx;
  flex-shrink: 0;
}

.nav-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  padding: 12rpx 0;
  white-space: nowrap;
}

/* ==================== 选择模式顶部栏 ==================== */
.select-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 8rpx;
}

.select-cancel {
  font-size: 28rpx;
  color: #666;
  min-width: 100rpx;
}

.select-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.select-confirm {
  font-size: 28rpx;
  color: #2E8B57;
  font-weight: 600;
  min-width: 100rpx;
  text-align: right;
}

/* ==================== 搜索栏 ==================== */
.search-section {
  padding: 16rpx 0 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 36rpx;
  height: 80rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 4rpx 12rpx;
}

/* ==================== 分类筛选 ==================== */
.category-filter {
  white-space: nowrap;
  padding-bottom: 16rpx;
  margin-bottom: 4rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  height: 56rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background: #fff;
  color: #666;
  border: 1rpx solid #e0e0e0;
  transition: all 0.2s;
  vertical-align: middle;
}

.filter-chip-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.filter-chip.active {
  background: #2E8B57;
  color: #fff;
  border-color: #2E8B57;
}

/* ==================== 排序栏 ==================== */
.sort-bar {
  display: flex;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-item {
  font-size: 26rpx;
  color: #999;
  margin-right: 40rpx;
  padding: 6rpx 0;
  position: relative;
}

.sort-item.active {
  color: #2E8B57;
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #2E8B57;
  border-radius: 2rpx;
}

/* ==================== 搜索结果提示 ==================== */
.search-result-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 12rpx 0 4rpx;
}

.result-label {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.result-count {
  font-size: 22rpx;
  color: #999;
}

/* ==================== 景点列表 ==================== */
.attraction-list {
  padding-top: 8rpx;
}

/* 选择模式下的景点行 */
.attraction-row.selectable {
  display: flex;
  align-items: flex-start;
}

.attraction-row.selectable .select-check {
  padding-top: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.attraction-row.selectable > attraction-card {
  flex: 1;
  min-width: 0;
}

/* 勾选框 */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #2E8B57;
  border-color: #2E8B57;
}

/* ==================== 选择模式底部栏 ==================== */
.select-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

/* ==================== 空状态 ==================== */
.empty-state {
  padding: 160rpx 0;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
