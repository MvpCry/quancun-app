/* pages/attractions/list/list.wxss - 景点列表样式 */

/* ========== 选择模式顶部栏 ========== */
.select-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 8rpx;
}

.select-cancel {
  font-size: 28rpx;
  color: var(--text-secondary);
  min-width: 100rpx;
}

.select-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.select-confirm {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  min-width: 100rpx;
  text-align: right;
}

/* 搜索 */
.search-section {
  padding: 16rpx 0 20rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.search-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 4rpx 12rpx;
}

/* 分类筛选 */
.category-filter {
  white-space: nowrap;
  padding-bottom: 16rpx;
  margin-bottom: 4rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 26rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #FFFFFF;
  color: var(--text-secondary);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
  vertical-align: middle;
}

.filter-chip-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.filter-chip.active {
  background: var(--primary);
  color: #FFFFFF;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.sort-item {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-right: 40rpx;
  padding: 6rpx 0;
  position: relative;
}

.sort-item.active {
  color: var(--primary);
  font-weight: 600;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* ========== 搜索结果提示 ========== */
.search-result-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 12rpx 0 4rpx;
}

.result-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.result-count {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ========== 景点列表 ========== */
.attraction-list {
  padding-top: 8rpx;
}

/* 选择模式下的景点行 */
.attraction-row.selectable {
  display: flex;
  align-items: flex-start;
}

.attraction-row.selectable .select-check {
  padding-top: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.attraction-row.selectable > attraction-card {
  flex: 1;
  min-width: 0;
}

/* 勾选框 */
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  transition: all 0.2s;
}

.checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

/* 选择模式底部栏 */
.select-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}

/* 空状态 */
.empty-state {
  padding: 160rpx 0;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}
