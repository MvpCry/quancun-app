<!-- pages/index/index.wxml - 首页 -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input class="search-field" placeholder="搜索景点、路线..." value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search"/>
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="onClearSearch">✕</text>
    </view>
    <button class="search-btn" bindtap="onSearch" size="mini">搜索</button>
  </view>

  <!-- 轮播Banner -->
  <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#FFFFFF" autoplay circular interval="4000">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-image" src="{{item.image}}" mode="aspectFill" binderror="onImageError" bindtap="onBannerTap" data-id="{{item.id}}" data-type="{{item.type}}"/>
      <view class="banner-info">
        <text class="banner-title">{{item.title}}</text>
        <text class="banner-desc">{{item.desc}}</text>
      </view>
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <view class="category-nav">
    <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-category="{{item.id}}" hover-class="category-item-hover">
      <view class="category-icon-wrap" catchtap="onCategoryTap" data-category="{{item.id}}">
        <image class="category-icon-img" src="{{item.icon}}" mode="aspectFit"/>
      </view>
      <text class="category-name" catchtap="onCategoryTap" data-category="{{item.id}}">{{item.name}}</text>
    </view>
  </view>

  <!-- 推荐路线 -->
  <view class="page-section">
    <view class="section-title">
      <text class="title">推荐路线</text>
      <text class="more" bindtap="onMoreRoutes">更多 ›</text>
    </view>
    <view class="route-list">
      <route-card wx:for="{{recommendRoutes}}" wx:key="_id" route="{{item}}" bindtap="onRouteTap" data-id="{{item._id}}"/>
    </view>
  </view>

  <!-- 精选景点 -->
  <view class="page-section">
    <view class="section-title">
      <text class="title">精选景点</text>
      <text class="more" bindtap="onMoreAttractions">更多 ›</text>
    </view>
    <view class="attraction-grid">
      <attraction-card wx:for="{{featuredAttractions}}" wx:key="_id" attraction="{{item}}" bindtap="onAttractionTap" data-id="{{item._id}}"/>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom" style="height: 40rpx;"></view>
</view>
