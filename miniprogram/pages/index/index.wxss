/* pages/index/index.wxss - 首页样式 */

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 16rpx 0 24rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  color: #BBBBBB;
  font-size: 28rpx;
}

/* ========== 轮播 ========== */
.banner-swiper {
  width: 100%;
  height: 340rpx;
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 28rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 40rpx 28rpx 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
}

.banner-title {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
}

.banner-desc {
  color: rgba(255,255,255,0.85);
  font-size: 24rpx;
}

/* ========== 分类导航 ========== */
.category-nav {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 8rpx;
  background: #FFFFFF;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 28rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
}

.category-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.category-icon {
  font-size: 42rpx;
}

.category-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ========== 热门景点滚动 ========== */
.hot-attractions-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.hot-attraction-item {
  display: inline-block;
  width: 260rpx;
  margin-right: 20rpx;
  background: #FFFFFF;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
}

.hot-attraction-item:last-child {
  margin-right: 0;
}

.hot-image {
  width: 100%;
  height: 180rpx;
}

.hot-info {
  padding: 16rpx;
}

.hot-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.hot-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hot-distance {
  font-size: 22rpx;
  color: var(--text-hint);
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ========== 精选景点网格 ========== */
.attraction-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.attraction-grid > attraction-card {
  width: calc(50% - 12rpx);
}
