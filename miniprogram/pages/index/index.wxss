/* pages/index/index.wxss - 首页（乡村绿主题 · 完整重构） */

/* ==================== 自定义导航栏 ==================== */
.nav-container {
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 0 0 48rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 16rpx;
  min-height: 140rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  overflow: hidden;
}

.nav-container.android {
  padding-top: calc(env(safe-area-inset-top) + 40rpx) !important;
  align-items: center;
}

.nav-left {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-left: 30rpx;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-right {
  width: 100rpx;
  flex-shrink: 0;
}

.nav-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  padding: 12rpx 0;
  white-space: nowrap;
}

/* ==================== 页面主体 ==================== */
.page-body {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ==================== 搜索区 ==================== */
.search-wrap {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx 24rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  height: 76rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-right: 16rpx;
}

.search-icon {
  font-size: 30rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 24rpx;
  color: #bbb;
  padding: 8rpx;
  flex-shrink: 0;
}

.search-btn {
  flex-shrink: 0;
  width: 100rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2E8B57;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
}

.search-btn:active {
  background: #228B22;
}

/* ==================== 轮播 Banner ==================== */
.banner-swiper {
  width: calc(100% - 48rpx);
  height: 360rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  pointer-events: none;
}

.banner-info {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 50rpx;
}

.banner-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner-desc {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ==================== 分类卡片 ==================== */
.category-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 图标区（五个等分，不滚动） */
.category-list {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-start;
  padding: 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.category-item-active {
  opacity: 0.7;
}

.icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #e8f5e9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-img {
  width: 56rpx;
  height: 56rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin-top: 12rpx;
  text-align: center;
  white-space: nowrap;
}

/* ==================== 通用区域 ==================== */
.section-wrap {
  margin-bottom: 8rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 20rpx;
}

.section-head-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  position: relative;
  padding-left: 20rpx;
}

.section-head-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 28rpx;
  background: #2E8B57;
  border-radius: 2rpx;
}

.section-head-more {
  font-size: 26rpx;
  color: #999;
}

.section-head-more:active {
  color: #2E8B57;
}

/* ==================== 推荐路线大卡片 ==================== */
.route-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin: 0 24rpx 20rpx;
  overflow: hidden;
}

/* 封面图 */
.rc-cover {
  position: relative;
  height: 320rpx;
}

.rc-cover-img {
  width: 100%;
  height: 100%;
  border-radius: 20rpx 20rpx 0 0;
}

.rc-cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(transparent 30%, rgba(0, 0, 0, 0.6) 100%);
  border-radius: 0 0 0 0;
  pointer-events: none;
}

.rc-cover-info {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.rc-cover-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.rc-cover-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.rc-cover-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
}

/* 内容区 */
.rc-body {
  padding: 24rpx;
}

.rc-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.rc-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.rc-meta-item {
  font-size: 24rpx;
  color: #666;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
}

.rc-meta-icon {
  margin-right: 6rpx;
  font-size: 22rpx;
}

.meta-green { color: #2E8B57; }
.meta-gray  { color: #999; }
.meta-red   { color: #ff4d4f; }

.rc-meta-like {
  margin-left: auto;
  margin-right: 0;
}

/* ==================== 精选景点横向滚动 ==================== */
.attr-scroll {
  white-space: nowrap;
  padding: 0 0 8rpx;
}

.attr-scroll-spacer {
  display: inline-block;
  width: 24rpx;
}

.attr-card {
  display: inline-block;
  width: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-right: 20rpx;
  overflow: hidden;
  vertical-align: top;
  white-space: normal;
}

.attr-card-active {
  opacity: 0.85;
}

.attr-cover {
  position: relative;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.attr-cover-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx 16rpx 0 0;
}

.attr-cover-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.attr-body {
  padding: 16rpx;
}

.attr-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attr-intro {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attr-meta {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.attr-rating {
  font-size: 22rpx;
  color: #FFB800;
  margin-right: 12rpx;
}

.attr-reviews {
  font-size: 20rpx;
  color: #999;
}

.attr-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.attr-address {
  font-size: 20rpx;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

.attr-price {
  font-size: 22rpx;
  color: #FF9800;
  font-weight: 500;
  flex-shrink: 0;
}

.attr-price.free {
  color: #2E8B57;
  font-weight: 600;
}

/* ==================== 底部安全区 ==================== */
.safe-bottom {
  height: 40rpx;
}
