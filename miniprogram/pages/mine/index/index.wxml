<!-- pages/mine/index/index.wxml - 我的页面（现代布局） -->

<!-- ==================== 主页面 ==================== -->
<view class="page-mine" wx:if="{{!activeTab}}">

  <!-- ===== 绿色头部区域（导航栏 + 用户信息 + 弧形过渡） ===== -->
  <view class="header-area {{isAndroid ? 'android' : ''}}">
    <!-- 导航栏 -->
    <view class="nav-bar">
      <text class="nav-title">我的</text>
    </view>

    <!-- 用户信息（绿色背景上） -->
    <view class="user-header" wx:if="{{isLogin}}">
      <view class="user-row">
        <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" bindtap="onLogin"/>
        <view class="user-meta">
          <text class="nickname">{{userInfo.nickName || '游客'}}</text>
          <text class="bio">探索乡村美景，从这里开始</text>
        </view>
      </view>
    </view>

    <view class="user-header" wx:else>
      <view class="user-row" bindtap="onLogin">
        <view class="avatar-placeholder">
          <text class="avatar-placeholder-icon">👤</text>
        </view>
        <view class="user-meta">
          <text class="nickname">点击登录</text>
          <text class="bio">登录后享受更多功能</text>
        </view>
        <text class="login-arrow">›</text>
      </view>
    </view>

  </view>

  <!-- ===== 数据统计卡片（负margin上叠） ===== -->
  <view class="stats-card" wx:if="{{isLogin}}">
    <view class="stat-item" bindtap="onTabTap" data-tab="favorites" hover-class="stat-active">
      <text class="stat-num">{{favoriteCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onTabTap" data-tab="routes" hover-class="stat-active">
      <text class="stat-num">{{myRouteCount}}</text>
      <text class="stat-label">我的路线</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onTabTap" data-tab="reviews" hover-class="stat-active">
      <text class="stat-num">{{myReviewCount}}</text>
      <text class="stat-label">我的评价</text>
    </view>
  </view>

  <!-- ===== 操作按钮区 ===== -->
  <view class="action-row" wx:if="{{isLogin}}">
    <view class="action-btn action-btn-primary" hover-class="action-btn-primary-active" bindtap="onCreateRoute">规划路线</view>
    <view class="action-btn action-btn-secondary" hover-class="action-btn-secondary-active" bindtap="onFeedback">意见反馈</view>
    <view class="action-btn-more" hover-class="action-btn-more-active" bindtap="onAbout">
      <text class="more-dots">⋯</text>
    </view>
  </view>

  <!-- ===== 功能菜单：常用功能 ===== -->
  <view class="menu-group">
    <text class="menu-group-title">常用功能</text>
    <view class="menu-card">
      <view class="menu-item" bindtap="onTabTap" data-tab="favorites" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">☆</text>
        </view>
        <text class="menu-text">我的收藏</text>
        <text class="menu-badge" wx:if="{{favoriteCount > 0}}">{{favoriteCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onTabTap" data-tab="routes" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">✦</text>
        </view>
        <text class="menu-text">我的路线</text>
        <text class="menu-badge" wx:if="{{myRouteCount > 0}}">{{myRouteCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onTabTap" data-tab="reviews" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">"</text>
        </view>
        <text class="menu-text">我的评价</text>
        <text class="menu-badge" wx:if="{{myReviewCount > 0}}">{{myReviewCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item menu-item-last" bindtap="onTabTap" data-tab="history" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">◷</text>
        </view>
        <text class="menu-text">浏览历史</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ===== 功能菜单：系统服务 ===== -->
  <view class="menu-group">
    <text class="menu-group-title">系统服务</text>
    <view class="menu-card">
      <view class="menu-item" bindtap="onNavigateTo" data-url="/pages/routes/plan/plan" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">◎</text>
        </view>
        <text class="menu-text">规划路线</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" wx:if="{{isAdmin}}" bindtap="onAdminEntry" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">⚙</text>
        </view>
        <text class="menu-text">后台管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onAbout" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">ⓘ</text>
        </view>
        <text class="menu-text">关于去俺村</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onFeedback" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">✎</text>
        </view>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item menu-item-last" bindtap="onSyncData" hover-class="menu-item-active">
        <view class="menu-icon-box menu-icon-green">
          <text class="menu-icon-symbol">↻</text>
        </view>
        <text class="menu-text">数据同步</text>
        <text class="menu-desc">更新坐标和路线数据</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ===== 底部区域 ===== -->
  <view class="footer-area">
    <view class="logout-btn" wx:if="{{isLogin}}" bindtap="onLogout" hover-class="logout-btn-active">退出登录</view>
  </view>

  <!-- 安全区适配 -->
  <view class="safe-bottom" style="height: 40rpx;"></view>
</view>

<!-- ==================== Tab 子页弹层（保持不变） ==================== -->
<view class="tab-content" wx:if="{{activeTab}}">
  <view class="tab-nav {{isAndroid ? 'android' : ''}}">
    <view class="tab-nav-left" bindtap="onCloseTab">
      <view class="nav-back">
        <text class="back-icon">{{backIcon}}</text>
      </view>
    </view>
    <view class="tab-nav-center">
      <text class="tab-nav-title">{{activeTab === 'favorites' ? '我的收藏' : activeTab === 'routes' ? '我的路线' : activeTab === 'reviews' ? '我的评价' : '浏览历史'}}</text>
    </view>
    <view class="tab-nav-right"></view>
  </view>

  <!-- 收藏列表 -->
  <view class="tab-body" wx:if="{{activeTab === 'favorites'}}">
    <block wx:if="{{tabList.length > 0}}">
      <view class="fav-item" wx:for="{{tabList}}" wx:key="_id" bindtap="onFavItemTap" data-item="{{item}}" hover-class="fav-item-active">
        <image class="fav-image" src="{{item.coverImage || item.images[0]}}" mode="aspectFill"/>
        <view class="fav-info">
          <text class="fav-name">{{item.name}}</text>
          <text class="fav-type-tag">{{item.favType === 'attraction' ? '景点' : '路线'}}</text>
        </view>
        <text class="fav-arrow">›</text>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon-circle">
        <text class="empty-icon-text">☆</text>
      </view>
      <text class="empty-title">还没有收藏</text>
      <text class="empty-desc">去发现感兴趣的景点和路线吧</text>
    </view>
  </view>

  <!-- 我的路线列表 -->
  <view class="tab-body" wx:if="{{activeTab === 'routes'}}">
    <block wx:if="{{tabList.length > 0}}">
      <view class="card-wrap" wx:for="{{tabList}}" wx:key="_id">
        <route-card route="{{item}}" bindtap="onRouteTap" data-id="{{item._id}}"/>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon-circle">
        <text class="empty-icon-text">✦</text>
      </view>
      <text class="empty-title">还没有路线</text>
      <text class="empty-desc">规划一条属于自己的旅行路线</text>
      <button class="empty-btn" bindtap="onCreateRoute">去创建路线</button>
    </view>
  </view>

  <!-- 我的评论列表 -->
  <view class="tab-body" wx:if="{{activeTab === 'reviews'}}">
    <block wx:if="{{tabList.length > 0}}">
      <view class="review-card" wx:for="{{tabList}}" wx:key="_id">
        <view class="review-card-top">
          <text class="review-card-name">{{item.attractionName}}</text>
          <star-rating rating="{{item.rating}}" size="small" readonly="{{true}}"/>
        </view>
        <text class="review-card-content">{{item.content}}</text>
        <view class="review-card-bottom">
          <text class="review-card-time">{{item.createTime}}</text>
          <text class="review-card-del" bindtap="onDeleteReview" data-id="{{item._id}}" data-name="{{item.attractionName}}" hover-class="review-card-del-active">删除</text>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon-circle">
        <text class="empty-icon-text">"</text>
      </view>
      <text class="empty-title">还没有评价</text>
      <text class="empty-desc">游览过景点后写下你的感受吧</text>
    </view>
  </view>

  <!-- 浏览历史列表 -->
  <view class="tab-body" wx:if="{{activeTab === 'history'}}">
    <block wx:if="{{tabList.length > 0}}">
      <view class="card-wrap" wx:for="{{tabList}}" wx:key="_id">
        <attraction-card attraction="{{item}}" bindtap="onAttractionTap" data-id="{{item._id}}"/>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon-circle">
        <text class="empty-icon-text">◷</text>
      </view>
      <text class="empty-title">暂无记录</text>
      <text class="empty-desc">浏览过的景点会出现在这里</text>
    </view>
  </view>
</view>
