<!-- pages/mine/index/index.wxml - 我的页面 -->
<view class="container">
  <!-- 用户信息卡 -->
  <view class="user-card card">
    <view class="user-info" wx:if="{{isLogin}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
      <view class="user-text">
        <text class="user-name">{{userInfo.nickName || '游客'}}</text>
        <text class="user-desc">探索乡村美景，从这里开始</text>
      </view>
      <text class="edit-btn">✎</text>
    </view>
    <view class="user-info" wx:else bindtap="onLogin">
      <view class="avatar-placeholder">
        <text>👤</text>
      </view>
      <view class="user-text">
        <text class="user-name">点击登录</text>
        <text class="user-desc">登录后享受更多功能</text>
      </view>
      <text class="login-arrow">›</text>
    </view>

    <!-- 统计数据 -->
    <view class="user-stats" wx:if="{{isLogin}}">
      <view class="stat" bindtap="onTabTap" data-tab="favorites">
        <text class="stat-num">{{favoriteCount}}</text>
        <text class="stat-label">收藏</text>
      </view>
      <view class="stat" bindtap="onTabTap" data-tab="routes">
        <text class="stat-num">{{myRouteCount}}</text>
        <text class="stat-label">我的路线</text>
      </view>
      <view class="stat" bindtap="onTabTap" data-tab="reviews">
        <text class="stat-num">{{myReviewCount}}</text>
        <text class="stat-label">我的评价</text>
      </view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="onTabTap" data-tab="favorites">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-badge" wx:if="{{favoriteCount > 0}}">{{favoriteCount}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onTabTap" data-tab="routes">
      <text class="menu-icon">🗺️</text>
      <text class="menu-text">我的路线</text>
      <text class="menu-badge" wx:if="{{myRouteCount > 0}}">{{myRouteCount}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onTabTap" data-tab="reviews">
      <text class="menu-icon">💬</text>
      <text class="menu-text">我的评价</text>
      <text class="menu-badge" wx:if="{{myReviewCount > 0}}">{{myReviewCount}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onTabTap" data-tab="history">
      <text class="menu-icon">🕐</text>
      <text class="menu-text">浏览历史</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item" bindtap="onNavigateTo" data-url="/pages/routes/plan/plan">
      <text class="menu-icon">📍</text>
      <text class="menu-text">规划路线</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于去俺村</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onFeedback">
      <text class="menu-icon">📝</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <button class="btn btn-outline btn-block" bindtap="onLogout">退出登录</button>
  </view>

  <view class="safe-bottom" style="height: 40rpx;"></view>
</view>

<!-- 我的收藏弹层 -->
<view class="tab-content" wx:if="{{activeTab}}">
  <view class="tab-header">
    <text class="tab-back" bindtap="onCloseTab">‹ 返回</text>
    <text class="tab-title">
      {{activeTab === 'favorites' ? '我的收藏' : ''}}
      {{activeTab === 'routes' ? '我的路线' : ''}}
      {{activeTab === 'reviews' ? '我的评价' : ''}}
      {{activeTab === 'history' ? '浏览历史' : ''}}
    </text>
    <view></view>
  </view>

  <!-- 收藏列表 -->
  <view class="tab-list" wx:if="{{activeTab === 'favorites'}}">
    <view wx:if="{{tabList.length > 0}}">
      <view class="fav-item" wx:for="{{tabList}}" wx:key="_id" bindtap="onFavItemTap" data-item="{{item}}">
        <image class="fav-image" src="{{item.coverImage || item.images[0]}}" mode="aspectFill" lazy-load/>
        <view class="fav-info">
          <text class="fav-name">{{item.name}}</text>
          <text class="fav-type tag tag-primary">{{item.favType === 'attraction' ? '景点' : '路线'}}</text>
        </view>
        <text class="fav-arrow">›</text>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text class="empty-icon">💝</text>
      <text class="empty-text">还没有收藏内容</text>
    </view>
  </view>

  <!-- 我的路线列表 -->
  <view class="tab-list" wx:if="{{activeTab === 'routes'}}">
    <route-card wx:for="{{tabList}}" wx:key="_id" route="{{item}}" bindtap="onRouteTap" data-id="{{item._id}}"/>
    <view class="empty-state" wx:if="{{tabList.length === 0}}">
      <text class="empty-icon">🗺️</text>
      <text class="empty-text">还没有创建路线</text>
      <button class="btn btn-primary btn-small mt-24" bindtap="onCreateRoute">去创建路线</button>
    </view>
  </view>

  <!-- 我的评论列表 -->
  <view class="tab-list" wx:if="{{activeTab === 'reviews'}}">
    <view class="review-item" wx:for="{{tabList}}" wx:key="_id">
      <view class="review-header">
        <text class="review-attraction-name">{{item.attractionName}}</text>
        <star-rating rating="{{item.rating}}" size="small" readonly="{{true}}"/>
      </view>
      <text class="review-text">{{item.content}}</text>
      <text class="review-date">{{item.createTime}}</text>
    </view>
    <view class="empty-state" wx:if="{{tabList.length === 0}}">
      <text class="empty-icon">💬</text>
      <text class="empty-text">还没有发表评价</text>
    </view>
  </view>

  <!-- 浏览历史列表 -->
  <view class="tab-list" wx:if="{{activeTab === 'history'}}">
    <attraction-card wx:for="{{tabList}}" wx:key="_id" attraction="{{item}}" bindtap="onAttractionTap" data-id="{{item._id}}"/>
    <view class="empty-state" wx:if="{{tabList.length === 0}}">
      <text class="empty-icon">🕐</text>
      <text class="empty-text">暂无浏览记录</text>
    </view>
  </view>
</view>
