/* pages/mine/index/index.wxss - 我的页面（现代布局 · 乡村绿主题） */

/* ==================== 色彩常量 ==================== */
/* 品牌绿 #2E8B57  深绿 #228B22  浅绿 #e8f5e9  浅绿bg #f0faf1 */
/* 文字 #1a1a1a / #666 / #999  分割线 #f0f0f0  页面底 #f5f5f5 */

/* ==================== 主页面容器 ==================== */
.page-mine {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 1. 绿色头部区域 ==================== */
.header-area {
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 60%, #f5f5f5 100%);
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.header-area.android {
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
}

/* ----- 导航栏 ----- */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 8rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

/* ----- 用户信息（绿色背景上） ----- */
.user-header {
  padding: 24rpx 32rpx 36rpx;
}

.user-row {
  display: flex;
  align-items: center;
}

/* 头像 */
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  margin-right: 24rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.15);
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-placeholder-icon {
  font-size: 56rpx;
  opacity: 0.7;
}

/* 昵称 + 简介 */
.user-meta {
  flex: 1;
  overflow: hidden;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bio {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 编辑资料按钮 — 毛玻璃风格 */
.edit-btn {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  margin-left: 16rpx;
}

.edit-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.login-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ==================== 2. 数据统计卡片 ==================== */
.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin: -40rpx 24rpx 0;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-active {
  opacity: 0.7;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

/* ==================== 3. 操作按钮区 ==================== */
.action-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx 20rpx;
}

.action-btn {
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}

.action-btn-primary {
  background: #2E8B57;
  color: #fff;
  margin-right: 12rpx;
}

.action-btn-primary-active {
  background: #228B22;
}

.action-btn-secondary {
  background: #e8f5e9;
  color: #2E8B57;
  margin-right: 12rpx;
}

.action-btn-secondary-active {
  background: #d0ebd3;
}

/* 更多按钮（圆形） */
.action-btn-more {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.action-btn-more-active {
  background: #e8e8e8;
}

.more-dots {
  font-size: 32rpx;
  color: #666;
  line-height: 1;
  letter-spacing: -4rpx;
}

/* ==================== 4. 功能菜单 ==================== */
.menu-group {
  margin-bottom: 20rpx;
}

.menu-group-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 32rpx 12rpx;
  display: block;
}

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item-last {
  border-bottom: none;
}

.menu-item-active {
  background: #fafafa;
}

/* 菜单图标 */
.menu-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-icon-green {
  background: #f0faf1;
}

.menu-icon-symbol {
  font-size: 30rpx;
  color: #2E8B57;
  line-height: 1;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-badge {
  background: #ff5252;
  color: #fff;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-right: 12rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #999;
  margin-right: 12rpx;
  flex: 1;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* ==================== 5. 底部区域 ==================== */
.footer-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0 24rpx;
}

.logout-btn {
  font-size: 28rpx;
  color: #ff4d4f;
  padding: 20rpx 80rpx;
  background: transparent;
  border-radius: 24rpx;
}

.logout-btn-active {
  background: rgba(255, 77, 79, 0.06);
}

.version-text {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 12rpx;
  padding: 12rpx 24rpx;
}

.version-text:active {
  opacity: 0.6;
}

/* 底部安全区 */
.safe-bottom {
  width: 100%;
}

/* ==================== 6. Tab 子页弹层 ==================== */
.tab-content {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f5f5f5;
  z-index: 200;
  overflow-y: auto;
}

/* Tab 导航栏 */
.tab-nav {
  display: flex;
  align-items: center;
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 16rpx;
  min-height: 140rpx;
  box-sizing: border-box;
  border-radius: 0 0 48rpx 48rpx;
}

.tab-nav.android {
  padding-top: calc(env(safe-area-inset-top) + 40rpx);
  align-items: center;
}

.tab-nav-left {
  width: 80rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.tab-nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.tab-nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
}

.tab-nav-right {
  width: 100rpx;
  flex-shrink: 0;
}

/* Tab 内容区 */
.tab-body {
  padding: 0;
}

/* ==================== 通用卡片包裹 ==================== */
.card-wrap {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-wrap:first-child {
  margin-top: 24rpx;
}

/* ==================== 7. 收藏项 ==================== */
.fav-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 16rpx;
}

.fav-item:first-child {
  margin-top: 24rpx;
}

.fav-item-active {
  background: #f8f8f8;
}

.fav-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.fav-info {
  flex: 1;
  overflow: hidden;
}

.fav-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #2E8B57;
  background: #e8f5e9;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.fav-arrow {
  font-size: 32rpx;
  color: #ccc;
  flex-shrink: 0;
}

/* ==================== 8. 评论卡片 ==================== */
.review-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.review-card:first-child {
  margin-top: 24rpx;
}

.review-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.review-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E8B57;
}

.review-card-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  margin-bottom: 12rpx;
}

.review-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.review-card-time {
  font-size: 22rpx;
  color: #999;
}

.review-card-del {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 6rpx 16rpx;
}

.review-card-del-active {
  background: rgba(255, 77, 79, 0.08);
}

/* ==================== 9. 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx 60rpx;
  background: #fff;
  border-radius: 16rpx;
  margin: 24rpx;
}

.empty-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon-text {
  font-size: 48rpx;
  color: #2E8B57;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: #2E8B57;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
  font-weight: 500;
}

.empty-btn::after {
  border: none;
}
