/* pages/mine/index/index.wxss - 我的页面样式 */

/* 用户卡片 */
.user-card {
  margin-top: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 36rpx 28rpx;
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #F0F0F0;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-right: 24rpx;
}

.user-text {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

.edit-btn, .login-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
}

/* 统计数据 */
.user-stats {
  display: flex;
  border-top: 1rpx solid var(--border);
  padding: 24rpx 0;
}

.stat {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 功能菜单 */
.menu-section {
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  width: 56rpx;
  text-align: center;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
}

.menu-badge {
  background: #FF5252;
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-right: 16rpx;
  flex: 1;
  text-align: right;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 0;
}

.admin-entry{display:flex;justify-content:center;padding:20rpx 0 40rpx}.admin-entry-text{font-size:22rpx;color:#CCC}
/* Tab内容面板 */
.tab-content {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F5F5;
  z-index: 200;
  overflow-y: auto;
}

/* 顶部栏 - 居中标题 */
.tab-header {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #2E7D32, #43A047);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-back {
  font-size: 36rpx;
  color: #FFFFFF;
  width: 60rpx;
  flex-shrink: 0;
}

.tab-placeholder {
  width: 60rpx;
  flex-shrink: 0;
}

.tab-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.tab-body {
  padding: 24rpx;
}

/* ===== 收藏项 ===== */
.fav-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.fav-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #F0F0F0;
  flex-shrink: 0;
}

.fav-info {
  flex: 1;
  overflow: hidden;
}

.fav-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #2E7D32;
  background: #E8F5E9;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.fav-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* ===== 我的评论卡片 ===== */
.review-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.review-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.review-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E7D32;
}

.review-card-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  display: block;
  margin-bottom: 12rpx;
}

.review-card-time {
  font-size: 22rpx;
  color: #BBB;
}

/* ===== 统一空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx 60rpx;
}

.empty-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #2E7D32, #43A047);
  color: #FFF;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
}

.empty-btn::after { border: none; }
