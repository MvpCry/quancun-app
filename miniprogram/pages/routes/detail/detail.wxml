<!-- pages/routes/detail/detail.wxml - 路线详情页 -->

<!-- ==================== 导航栏 ==================== -->
<view class="nav-container {{isAndroid ? 'android' : ''}}">
  <view class="nav-left">
    <view class="nav-back" bindtap="onNavBack">
      <text class="back-icon">{{backIcon}}</text>
    </view>
  </view>
  <view class="nav-center">
    <text class="nav-title">{{route.name || '路线详情'}}</text>
  </view>
  <view class="nav-right"></view>
</view>

<view class="container">

  <!-- ========== 0. 加载中 ========== -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载路线信息...</text>
  </view>

  <!-- ========== 0. 加载失败 ========== -->
  <view class="error-state" wx:elif="{{loadError}}">
    <text class="error-icon">😞</text>
    <text class="error-text">{{loadError}}</text>
    <button class="error-retry-btn" bindtap="onRetry">重新加载</button>
    <button class="error-back-btn" bindtap="onNavBack">返回列表</button>
  </view>

  <block wx:else>

  <!-- 导航 map（导航模式下显示，替换原路线地图） -->
  <view class="nav-map-section" wx:if="{{showNavResult || isPlanning}}">
    <map
      id="routeMap"
      class="detail-map-nav"
      latitude="{{markers[0].latitude || 36.2}}"
      longitude="{{markers[0].longitude || 117.1}}"
      scale="10"
      markers="{{markers}}"
      polyline="{{polyline}}"
      show-location
      show-compass
    />
    <view class="route-loading-overlay" wx:if="{{isPlanning}}">
      <text>计算线路中...</text>
    </view>
  </view>

  <!-- 原始路线地图（非导航模式） -->
  <view class="detail-map-section" wx:elif="{{hasMapData}}">
    <map-route
      id="detailMapRoute"
      stops="{{mapStops}}"
      routePolylines="{{routePolylines}}"
      height="450"
      showLocation="{{true}}"
      showStops="{{true}}"
      currentIndex="{{currentStopIndex}}"
      bindstopchange="onStopChange"
    />
  </view>
  <!-- 无坐标提示 -->
  <view class="no-map-hint" wx:elif="{{route.attractions && route.attractions.length > 0}}">
    <view class="no-map-content">
      <text class="no-map-icon">🗺️</text>
      <text class="no-map-text">路线坐标待录入</text>
      <text class="no-map-desc">请通过后台管理页面设置景点坐标后，路线将自动展示</text>
    </view>
  </view>

  <!-- 路线信息 -->
  <view class="route-header card">
    <view class="card-body">
      <text class="route-name">{{route.name}}</text>
      <view class="route-stats">
        <view class="stat-item">
          <text class="stat-value">{{route.attractionCount || 0}}</text>
          <text class="stat-label">景点</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{route.totalDistance || '--'}}</text>
          <text class="stat-label">公里</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{route.estimatedTime || '--'}}</text>
          <text class="stat-label">小时</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{route.likeCount || 0}}</text>
          <text class="stat-label">收藏</text>
        </view>
      </view>

      <view class="route-tags" wx:if="{{route.tags && route.tags.length > 0}}">
        <text class="tag tag-primary" wx:for="{{route.tags}}" wx:key="*this">{{item}}</text>
      </view>

      <text class="route-desc">{{route.description}}</text>
    </view>
  </view>

  <!-- 景点列表 -->
  <view class="stops-card card">
    <view class="card-header">
      <text class="card-title">途经景点</text>
    </view>
    <view class="stops-list">
      <view class="stop-row {{index === currentStopIndex ? 'active' : ''}}"
        wx:for="{{route.attractions}}" wx:key="attractionId"
        data-index="{{index}}"
        bindtap="onStopRowTap">
        <view class="stop-indicator">
          <view class="stop-marker-dot {{index === 0 ? 'start' : ''}} {{index === route.attractions.length - 1 ? 'end' : ''}}">
            <text>{{index + 1}}</text>
          </view>
          <view class="stop-marker-line" wx:if="{{index < route.attractions.length - 1}}"></view>
        </view>
        <view class="stop-content-wrap">
          <text class="stop-title">{{item.displayName || item.name}}</text>
          <text class="stop-distance" wx:if="{{item.distanceFromPrev}}">距上站 {{item.distanceFromPrev}}km</text>
        </view>
        <text class="stop-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 导航结果浮层 -->
  <view class="nav-result-panel" wx:if="{{showNavResult}}">
    <view class="nav-result-header">
      <view class="nav-modes">
        <view class="mode {{navMode === 'driving' ? 'active' : ''}}"
              data-mode="driving" bindtap="switchNavMode">驾车</view>
        <view class="mode {{navMode === 'walking' ? 'active' : ''}}"
              data-mode="walking" bindtap="switchNavMode">步行</view>
        <view class="mode {{navMode === 'bicycling' ? 'active' : ''}}"
              data-mode="bicycling" bindtap="switchNavMode">骑行</view>
      </view>
      <view class="close-btn" bindtap="closeNavResult">✕</view>
    </view>
    <view class="nav-result-body">
      <text class="nav-time">{{navInfo.duration}}</text>
      <text class="nav-distance">{{navInfo.distance}}</text>
    </view>
  </view>

  <view style="height: 140rpx;"></view>

  <!-- 底部操作栏：未计算线路 -->
  <view class="detail-bottom-bar safe-bottom" wx:if="{{!showNavResult}}">
    <view class="bottom-action" bindtap="onToggleFavorite">
      <text>{{isFavorited ? '❤️' : '🤍'}}</text>
      <text class="bottom-label">收藏</text>
    </view>
    <view class="bottom-action" bindtap="onShare">
      <text>📤</text>
      <text class="bottom-label">分享</text>
    </view>
    <button class="btn btn-primary flex-1 {{isPlanning ? 'loading' : ''}}" bindtap="onNavigateAll">
      {{isPlanning ? '计算中...' : '计算线路'}}
    </button>
  </view>

  <!-- 底部操作栏：已计算线路 → 去导航 + 关闭 -->
  <view class="detail-bottom-bar dual-mode safe-bottom" wx:if="{{showNavResult}}">
    <view class="btn-navigate" bindtap="goToTencentMap">
      <text>🧭 去导航</text>
    </view>
    <view class="btn-close" bindtap="closeNavResult">
      <text>✕ 关闭</text>
    </view>
  </view>
  </block>
</view>
