/* pages/routes/detail/detail.wxss - 路线详情样式 */

/* ==================== 自定义导航栏 ==================== */
.nav-container {
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 0 0 48rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 16rpx;
  min-height: 140rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  overflow: hidden;
}
.nav-container.android {
  padding-top: calc(env(safe-area-inset-top) + 40rpx) !important;
  align-items: center;
}
.nav-left { width: 100rpx; flex-shrink: 0; display: flex; align-items: center; padding-left: 16rpx; }
.nav-center { flex: 1; display: flex; justify-content: center; align-items: center; }
.nav-right { width: 100rpx; flex-shrink: 0; }
.nav-title { font-size: 34rpx; color: #fff; font-weight: 600; padding: 12rpx 0; white-space: nowrap; }
.nav-back {
  width: 64rpx; height: 64rpx;
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.back-icon { color: #fff; font-size: 36rpx; font-weight: 600; line-height: 1; }

/* 页面容器 — 底部留出固定栏高度防止遮挡 */
.container {
  padding-bottom: 160rpx;
}

/* ==================== 加载/错误状态 ==================== */
.loading-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 200rpx 0; gap: 24rpx;
}
.loading-spinner {
  width: 60rpx; height: 60rpx;
  border: 4rpx solid #E8E8E8; border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin2 0.8s linear infinite;
}
@keyframes spin2 { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #999; }

.error-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 200rpx 48rpx; gap: 20rpx;
}
.error-icon { font-size: 80rpx; margin-bottom: 8rpx; }
.error-text { font-size: 28rpx; color: #999; text-align: center; line-height: 1.6; }
.error-retry-btn {
  margin-top: 24rpx; padding: 18rpx 64rpx;
  font-size: 28rpx; color: #FFF; background: #2E8B57;
  border-radius: 44rpx; border: none;
}
.error-retry-btn::after { border: none; }
.error-back-btn {
  margin-top: 12rpx; padding: 18rpx 64rpx;
  font-size: 28rpx; color: #999; background: #F5F5F5;
  border-radius: 44rpx; border: none;
}
.error-back-btn::after { border: none; }

/* 地图 */
.detail-map-section {
  margin: 0 -24rpx 24rpx;
  border-radius: 0 0 var(--radius) var(--radius);
  overflow: hidden;
}

/* 无坐标提示 */
.no-map-hint {
  margin: 0 0 24rpx;
  background: #FAFAFA;
  border-radius: var(--radius);
  min-height: 240rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.no-map-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.no-map-icon {
  font-size: 56rpx;
  opacity: 0.4;
}

.no-map-text {
  font-size: 28rpx;
  color: var(--text-hint);
  font-weight: 500;
}

.no-map-desc {
  font-size: 22rpx;
  color: #CCCCCC;
  text-align: center;
  padding: 0 40rpx;
}

/* 路线信息 */
.route-header {
  margin-bottom: 24rpx;
}

.route-name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 20rpx;
}

.route-stats {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8FFF8;
  border-radius: var(--radius);
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--border);
}

.route-tags {
  margin-bottom: 14rpx;
}

.route-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 景点卡片 */
.stops-card .card-header {
  padding: 24rpx 24rpx 0;
}

.stops-list {
  padding: 8rpx 24rpx 24rpx;
}

.stop-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  position: relative;
}

.stop-row.active {
  background: #F1F8E9;
  margin: 0 -24rpx;
  padding: 18rpx 24rpx;
  border-radius: 8rpx;
}

.stop-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  min-height: 60rpx;
}

.stop-marker-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--primary-light);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(46,125,50,0.25);
}

.stop-marker-dot.start {
  background: var(--accent);
}

.stop-marker-dot.end {
  background: var(--primary);
}

.stop-marker-line {
  width: 2rpx;
  flex: 1;
  background: #DDDDDD;
  margin: 4rpx 0;
  min-height: 32rpx;
}

.stop-content-wrap {
  flex: 1;
}

.stop-title {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.stop-distance {
  font-size: 22rpx;
  color: var(--text-hint);
}

.stop-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
}

/* 操作按钮 */
.action-buttons {
  padding: 8rpx 0;
  margin-bottom: 120rpx;
}

/* 底部操作栏 */
.detail-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  gap: 16rpx;
  z-index: 100;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 36rpx;
  padding: 4rpx 12rpx;
}

.bottom-label {
  font-size: 20rpx;
  color: var(--text-hint);
}
