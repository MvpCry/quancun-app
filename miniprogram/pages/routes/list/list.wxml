<!-- pages/routes/list/list.wxml - 路线列表页 -->
<view class="nav-container {{isAndroid ? 'android' : ''}}">
  <view class="nav-left"></view>
  <view class="nav-center">
    <text class="nav-title">路线</text>
  </view>
  <view class="nav-right"></view>
</view>
<view class="container">
  <!-- 顶部标签筛选 -->
  <view class="section-header">
    <text class="section-header-title">探索路线</text>
    <text class="section-header-desc">精选乡村旅游路线，一键出发</text>
  </view>

  <!-- 标签筛选 -->
  <scroll-view class="tag-filter" scroll-x enable-flex>
    <view class="tag-chip {{activeTag === '' ? 'active' : ''}}" bindtap="onTagChange" data-tag="">全部</view>
    <view class="tag-chip {{activeTag === item.id ? 'active' : ''}}"
      wx:for="{{routeTags}}" wx:key="id"
      bindtap="onTagChange"
      data-tag="{{item.id}}">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 路线列表（外层 view 绑 data-id + bindtap，与景点列表页完全一致） -->
  <view class="route-list" wx:if="{{routes.length > 0}}">
    <view wx:for="{{routes}}" wx:key="_id" bindtap="onRouteTap" data-id="{{item._id}}">
      <route-card route="{{item}}"/>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && routes.length === 0}}">
    <text class="empty-icon">{{activeTag ? '📭' : '🗺️'}}</text>
    <text class="empty-text">{{activeTag ? '暂无' + activeTag : '暂无路线'}}</text>
    <text class="empty-desc" wx:if="{{activeTag}}">该分类下暂未收录路线，敬请期待</text>
    <button class="btn btn-primary btn-small mt-24" bindtap="onCreateRoute">去创建路线</button>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && routes.length > 0}}">
    <text wx:if="{{loadingMore}}">正在加载...</text>
    <text wx:else bindtap="loadMore">点击加载更多</text>
  </view>

  <!-- 创建路线悬浮按钮 -->
  <view class="fab" bindtap="onCreateRoute">
    <text class="fab-icon">+</text>
    <text class="fab-text">规划路线</text>
  </view>

  <view class="safe-bottom" style="height: 120rpx;"></view>
</view>
