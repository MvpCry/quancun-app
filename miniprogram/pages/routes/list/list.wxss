/* pages/routes/list/list.wxss */

/* 自定义导航栏 */
.nav-container{width:100%;background:#207c30;box-sizing:border-box;padding-top:calc(env(safe-area-inset-top) + 36rpx);padding-bottom:16rpx;min-height:140rpx;display:flex;flex-direction:row;align-items:flex-end;justify-content:space-between;}
.nav-container.android{padding-top:calc(env(safe-area-inset-top) + 40rpx)!important;align-items:center}
.nav-left{width:100rpx;flex-shrink:0;display:flex;align-items:center;padding-left:30rpx}.nav-center{flex:1;display:flex;justify-content:center;align-items:center}.nav-right{width:180rpx;flex-shrink:0}.nav-title{font-size:36rpx;color:#fff;font-weight:600;padding:12rpx 0;white-space:nowrap}

.section-header {
  padding: 24rpx 0 16rpx;
}

.section-header-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.section-header-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 标签筛选 */
.tag-filter {
  white-space: nowrap;
  padding: 12rpx 0 24rpx;
}

.tag-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #FFFFFF;
  color: var(--text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.tag-chip.active {
  background: var(--primary);
  color: #FFFFFF;
}

/* 路线列表 */
.route-list {
  padding-top: 8rpx;
}

/* 空状态扩展 */
.empty-desc {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  display: flex;
  align-items: center;
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 18rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(46,125,50,0.35);
  z-index: 50;
}

.fab-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
  font-weight: 300;
}

.fab-text {
  font-size: 26rpx;
  font-weight: 500;
}
