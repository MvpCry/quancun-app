/* pages/routes/list/list.wxss - 路线列表样式（森林绿统一规范） */

/* ==================== 自定义导航栏 ==================== */
.nav-container {
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 0 0 48rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 16rpx;
  min-height: 140rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  overflow: hidden;
}

.nav-container.android {
  padding-top: calc(env(safe-area-inset-top) + 40rpx) !important;
  align-items: center;
}

.nav-left {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-left: 30rpx;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-right {
  width: 180rpx;
  flex-shrink: 0;
}

.nav-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  padding: 12rpx 0;
  white-space: nowrap;
}

/* ==================== 顶部标题区 ==================== */
.section-header {
  padding: 24rpx 0 16rpx;
}

.section-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 8rpx;
}

.section-header-desc {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 标签筛选 ==================== */
.tag-filter {
  white-space: nowrap;
  padding: 12rpx 0 24rpx;
}

.tag-chip {
  display: inline-block;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background: #fff;
  color: #666;
  border: 1rpx solid #e0e0e0;
  transition: all 0.2s;
}

.tag-chip.active {
  background: #2E8B57;
  color: #fff;
  border-color: #2E8B57;
}

/* ==================== 路线列表 ==================== */
.route-list {
  padding-top: 8rpx;
}

/* ==================== 空状态扩展 ==================== */
.empty-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* ==================== 悬浮按钮 ==================== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  display: flex;
  align-items: center;
  background: #2E8B57;
  color: #fff;
  border-radius: 36rpx;
  height: 80rpx;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 139, 87, 0.3);
  z-index: 50;
}

.fab:active {
  background: #228B22;
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.2);
}

.fab-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
  font-weight: 300;
}

.fab-text {
  font-size: 26rpx;
  font-weight: 500;
}
