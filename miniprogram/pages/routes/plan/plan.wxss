/* pages/routes/plan/plan.wxss - 路线规划页样式 */

.plan-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* 地图区域 */
.plan-map-wrap {
  position: relative;
  flex-shrink: 0;
}

.map-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.7);
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

/* 底部面板 */
.plan-bottom {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.plan-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
}

.panel-action {
  font-size: 26rpx;
  color: var(--primary);
}

/* 已选景点列表 */
.selected-list {
  flex: 1;
  padding: 8rpx 32rpx;
}

.selected-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.selected-order {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--bg-page);
  color: var(--text-secondary);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.selected-info {
  flex: 1;
  min-width: 0;
}

.selected-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.selected-address {
  font-size: 22rpx;
  color: var(--text-hint);
}

.selected-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selected-delete {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FFEBEE;
  color: #F44336;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.selected-drag {
  color: var(--text-hint);
  font-size: 28rpx;
}

/* 空状态 */
.empty-selected {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.empty-selected .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-selected .empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-selected .empty-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 路线统计 */
.route-summary {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  margin: 16rpx 32rpx;
  border-radius: var(--radius);
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-dark);
  display: block;
}

.summary-label {
  font-size: 22rpx;
  color: var(--primary);
}

.summary-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(46,125,50,0.2);
}

/* 已规划景点列表 */
.planned-stops {
  flex: 1;
  padding: 8rpx 32rpx;
}

.planned-stop {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  transition: background 0.2s;
}

.planned-stop.current {
  background: #F1F8E9;
  margin: 0 -32rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
}

.stop-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.stop-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary-light);
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}

.stop-dot.start {
  width: 22rpx;
  height: 22rpx;
  background: var(--accent);
}

.stop-dot.end {
  width: 22rpx;
  height: 22rpx;
  background: var(--primary);
}

.stop-line {
  width: 2rpx;
  flex: 1;
  min-height: 32rpx;
  background: #DDDDDD;
  margin: 4rpx 0;
}

.stop-content {
  flex: 1;
}

.stop-title {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.stop-meta {
  font-size: 22rpx;
  color: var(--text-hint);
}

.stop-order {
  font-size: 28rpx;
  color: var(--text-hint);
  font-weight: 600;
}

/* 底部操作 */
.panel-footer {
  padding: 20rpx 32rpx;
  border-top: 1rpx solid var(--border);
}

.footer-row {
  margin-bottom: 16rpx;
}

.route-name-input {
  width: 100%;
  height: 72rpx;
  background: var(--bg-page);
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
