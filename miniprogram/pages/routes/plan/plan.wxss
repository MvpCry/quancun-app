/* pages/routes/plan/plan.wxss - 路线规划页（卡片列表风格） */

.plan-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* ==================== 自定义导航栏 ==================== */
.nav-container {
  width: 100%;
  background: linear-gradient(180deg, #2E8B57 0%, #3CB371 100%);
  padding-top: calc(env(safe-area-inset-top) + 36rpx);
  padding-bottom: 16rpx;
  min-height: 140rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  border-radius: 0 0 48rpx 48rpx;
  flex-shrink: 0;
}

.nav-left {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-left: 16rpx;
}

.nav-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-right {
  width: 100rpx;
  flex-shrink: 0;
}

.nav-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  padding: 12rpx 0;
  white-space: nowrap;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1;
}

/* ==================== 地图区域 ==================== */
.plan-map-wrap {
  position: relative;
  flex-shrink: 0;
}

.map-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

/* ==================== 坐标缺失警告 ==================== */
.coord-warning {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  margin: 0 24rpx 12rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  border-left: 6rpx solid #FF9800;
}

.coord-warning-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.coord-warning-text {
  font-size: 24rpx;
  color: #E65100;
  line-height: 1.5;
}

/* ==================== 底部面板 ==================== */
.plan-bottom {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.plan-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -20rpx;
  padding: 24rpx;
  position: relative;
  z-index: 10;
}

/* ==================== 标题卡片 ==================== */
.panel-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.panel-action {
  font-size: 26rpx;
  color: #2E8B57;
}

/* ==================== 已选景点列表卡片 ==================== */
.selected-list-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.selected-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.selected-item:last-child {
  border-bottom: none;
}

.selected-order {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8f5e9;
  color: #2E8B57;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.selected-info {
  flex: 1;
  min-width: 0;
}

.selected-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.selected-address {
  font-size: 24rpx;
  color: #999;
}

.selected-delete {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffebee;
  color: #f44336;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.selected-drag {
  color: #ccc;
  font-size: 28rpx;
}

/* ==================== 空状态卡片 ==================== */
.empty-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 48rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* ==================== 路线统计卡片 ==================== */
.summary-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
}

.summary-divider {
  width: 1rpx;
  height: 48rpx;
  background: #f0f0f0;
}

/* ==================== 已规划路线列表 ==================== */
.stops-list-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  padding: 0 28rpx;
}

.planned-stop {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.planned-stop:last-child {
  border-bottom: none;
}

.planned-stop.current {
  background: #f0faf1;
  margin: 0 -28rpx;
  padding: 24rpx 28rpx;
}

.stop-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.stop-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #3CB371;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.stop-dot.start {
  width: 22rpx;
  height: 22rpx;
  background: #FF9800;
}

.stop-dot.end {
  width: 22rpx;
  height: 22rpx;
  background: #2E8B57;
}

.stop-line {
  width: 2rpx;
  flex: 1;
  min-height: 32rpx;
  background: #e0e0e0;
  margin: 4rpx 0;
}

.stop-content {
  flex: 1;
  min-width: 0;
}

.stop-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.stop-meta {
  font-size: 22rpx;
  color: #999;
}

.stop-order {
  font-size: 28rpx;
  color: #999;
  font-weight: 600;
  flex-shrink: 0;
}

/* ==================== 底部操作 ==================== */
.panel-footer {
  padding: 0;
}

.footer-row {
  margin-bottom: 16rpx;
}

.route-name-input {
  width: 100%;
  height: 80rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* ==================== 统一按钮 ==================== */
.plan-btn {
  width: 100%;
  height: 80rpx;
  background: #2E8B57;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.plan-btn::after {
  border: none;
}

.plan-btn[disabled] {
  background: #bbb;
  color: #fff;
}
